# AutoSync V3 — Required Environment Variables
# Copy this to .env and fill in your values

# ── Shopify App ──
SHOPIFY_API_KEY=your_api_key
SHOPIFY_API_SECRET=your_api_secret
SCOPES=write_products,read_products,read_themes,write_themes,read_content,write_content,read_metaobjects,write_metaobjects,read_metaobject_definitions,write_metaobject_definitions,write_publications,read_publications
SHOPIFY_APP_URL=https://your-app.vercel.app

# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Prisma (Shopify session storage) ──
POSTGRES_PRISMA_URL=postgresql://postgres.your-project:password@pooler.supabase.com:6543/postgres?pgbouncer=true
POSTGRES_URL_NON_POOLING=postgresql://postgres.your-project:password@db.supabase.com:5432/postgres

# ── DVLA/MOT (Enterprise features — UK plate lookup) ──
DVLA_API_KEY=your_dvla_ves_api_key
MOT_API_KEY=your_mot_history_api_key
MOT_CLIENT_ID=your_mot_oauth_client_id
MOT_CLIENT_SECRET=your_mot_oauth_client_secret

# ── Encryption (for sensitive data at rest — FTP passwords etc.) ──
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_hex_character_key_here

# ── Admin Shops (comma-separated shop domains with admin panel access) ──
# ADMIN_SHOPS=your-store.myshopify.com

# ── Billing (set to "true" only for development) ──
# BILLING_TEST_MODE=true
