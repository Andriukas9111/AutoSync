    transition: gap 0.2s ease;
  }

  .autosync-vsp__product-card:hover .autosync-vsp__product-cta {
    gap: 10px;
  }

  /* --- Footer --- */
  .autosync-vsp__footer {
    padding: 20px;
    text-align: center;
    font-size: 12px;
    color: var(--vsp-text-muted);
    border-top: 1px solid var(--vsp-border);
  }

  .autosync-vsp__footer strong {
    color: var(--vsp-accent);
    font-weight: 700;
  }

  /* --- Responsive --- */
  @media (max-width: 768px) {
    .autosync-vsp__hero-inner {
      padding: 32px 20px 40px;
      flex-direction: column;
      text-align: center;
    }

    .autosync-vsp__hero-graphic {
      width: 100px;
      height: 100px;
      order: -1;
    }

    .autosync-vsp__hero-badges {
      justify-content: center;
    }

    .autosync-vsp__hero-highlight {
      justify-content: center;
    }

    .autosync-vsp__breadcrumb {
      justify-content: center;
    }

    .autosync-vsp__quickbar-inner {
      padding: 0 16px;
    }

    .autosync-vsp__quickbar-item {
      padding: 14px 16px;
      gap: 8px;
    }

    .autosync-vsp__body {
      padding: 20px 16px 40px;
      gap: 20px;
    }

    .autosync-vsp__section-header {
      padding: 16px 16px;
    }

    .autosync-vsp__overview-text {
      padding: 16px;
      font-size: 14px;
    }

    .autosync-vsp__spec-group-header {
      padding: 14px 16px;
      font-size: 14px;
    }

    .autosync-vsp__spec-key,
    .autosync-vsp__spec-val {
      padding: 10px 16px;
      font-size: 13px;
    }

    .autosync-vsp__spec-key {
      width: 45%;
    }

