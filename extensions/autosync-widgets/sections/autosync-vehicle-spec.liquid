<style>
  /* --- Reset & Container --- */
  .autosync-vsp {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
    color: var(--vsp-text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    background: var(--vsp-body-bg);
  }

  .autosync-vsp *,
  .autosync-vsp *::before,
  .autosync-vsp *::after {
    box-sizing: border-box;
  }

  /* --- Hero --- */
  .autosync-vsp__hero {
    background: var(--vsp-hero-bg);
    color: var(--vsp-hero-text);
    position: relative;
    overflow: hidden;
  }

  .autosync-vsp__hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(255,255,255,0.03) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(255,255,255,0.05) 0%, transparent 50%);
    pointer-events: none;
  }

  .autosync-vsp__hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 24px 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    position: relative;
    z-index: 1;
  }

  .autosync-vsp__hero-content {
    flex: 1;
    min-width: 0;
  }

  .autosync-vsp__hero-graphic {
    flex: 0 0 auto;
    width: 140px;
    height: 140px;
    opacity: 0.6;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .autosync-vsp__hero-icon {
    width: 100%;
    height: 100%;
  }

  .autosync-vsp__breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    opacity: 0.7;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .autosync-vsp__breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .autosync-vsp__breadcrumb a:hover {
    text-decoration: underline;
    opacity: 1;
  }

  .autosync-vsp__hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .autosync-vsp__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .autosync-vsp__badge--year {
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.2);
  }

  .autosync-vsp__badge--gen {
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.15);
  }

  .autosync-vsp__badge--body {
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.12);
  }

  .autosync-vsp__badge--count {
    background: var(--vsp-accent);
    color: #fff;
    font-size: 12px;
    padding: 2px 10px;
    border-radius: 100px;
    margin-left: auto;
  }

  .autosync-vsp__hero-title {
    font-size: clamp(28px, 5vw, 44px);
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }

  .autosync-vsp__hero-variant {
    font-size: clamp(15px, 2.2vw, 19px);
    opacity: 0.75;
    margin: 0 0 24px;
    font-weight: 400;
    line-height: 1.4;
  }

  .autosync-vsp__hero-highlight {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.15);
  }

  .autosync-vsp__hero-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .autosync-vsp__hero-stat-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.5;
    font-weight: 600;
  }

  .autosync-vsp__hero-stat-value {
    font-size: 16px;
    font-weight: 700;
  }

  /* --- Quick Specs Bar --- */
  .autosync-vsp__quickbar {
    background: var(--vsp-card-bg);
    border-bottom: 1px solid var(--vsp-border);
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    position: relative;
    z-index: 2;
  }

  .autosync-vsp__quickbar-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    gap: 0;
  }

  .autosync-vsp__quickbar-inner::-webkit-scrollbar {
    display: none;
  }

  .autosync-vsp__quickbar-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 20px;
    white-space: nowrap;
    border-right: 1px solid var(--vsp-border);
    flex-shrink: 0;
    min-width: 0;
    transition: background 0.15s ease;
  }

  .autosync-vsp__quickbar-item:first-child {
    border-left: 1px solid var(--vsp-border);
  }

  .autosync-vsp__quickbar-item:hover {
    background: var(--vsp-accent-light);
  }

  .autosync-vsp__quickbar-icon {
    color: var(--vsp-accent);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .autosync-vsp__quickbar-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .autosync-vsp__quickbar-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--vsp-text-muted);
    font-weight: 600;
  }

  .autosync-vsp__quickbar-value {
    font-size: 13px;
    font-weight: 700;
    color: var(--vsp-text);
  }

  /* --- Body / Section Wrappers --- */
  .autosync-vsp__body {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 24px 60px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .autosync-vsp__section {
    background: var(--vsp-card-bg);
    border-radius: var(--vsp-radius);
    border: 1px solid var(--vsp-border);
    overflow: hidden;
  }

  .autosync-vsp__section-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 20px 24px;
    border-bottom: 1px solid var(--vsp-border);
  }

  .autosync-vsp__section-icon {
    color: var(--vsp-accent);
    flex-shrink: 0;
  }

  .autosync-vsp__section-title {
    font-size: 18px;
    font-weight: 700;
    margin: 0;
    color: var(--vsp-text);
    letter-spacing: -0.01em;
  }

  /* --- Overview --- */
  .autosync-vsp__overview-text {
    padding: 24px;
    font-size: 15px;
    line-height: 1.75;
    color: var(--vsp-text);
  }

  /* --- Specs Accordion --- */
  .autosync-vsp__specs-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 40px;
    color: var(--vsp-text-muted);
    font-size: 14px;
  }

  .autosync-vsp__spinner {
    width: 20px;
    height: 20px;
    border: 2px solid var(--vsp-border);
    border-top-color: var(--vsp-accent);
    border-radius: 50%;
    animation: vsp-spin 0.6s linear infinite;
  }

  @keyframes vsp-spin {
    to { transform: rotate(360deg); }
  }

  .autosync-vsp__spec-group {
    border-bottom: 1px solid var(--vsp-border);
  }

  .autosync-vsp__spec-group:last-child {
    border-bottom: none;
  }

  .autosync-vsp__spec-group-header {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 16px 24px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    font-size: 15px;
    font-weight: 600;
    color: var(--vsp-text);
    transition: background 0.15s ease;
  }

  .autosync-vsp__spec-group-header:hover {
    background: var(--vsp-row-alt);
  }

  .autosync-vsp__spec-group-icon {
    color: var(--vsp-accent);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .autosync-vsp__spec-group-name {
    flex: 1;
    min-width: 0;
  }

  .autosync-vsp__spec-group-count {
    font-size: 12px;
    font-weight: 500;
    color: var(--vsp-text-muted);
    white-space: nowrap;
  }

  .autosync-vsp__spec-group-chevron {
    flex-shrink: 0;
    color: var(--vsp-text-muted);
    transition: transform 0.25s ease;
  }

  .autosync-vsp__spec-group--open > .autosync-vsp__spec-group-header .autosync-vsp__spec-group-chevron {
    transform: rotate(180deg);
  }

  .autosync-vsp__spec-group-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .autosync-vsp__spec-group--open > .autosync-vsp__spec-group-body {
    max-height: 2000px;
  }

  .autosync-vsp__spec-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .autosync-vsp__spec-row--even {
