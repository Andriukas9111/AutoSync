{% comment %}
  AutoSync Vehicle Showcase — Premium Gallery
  Displays a browsable gallery of all vehicle specification pages.
  Add this block to any page (home, collection, custom page) to showcase
  all vehicles with fitment data. Each card links to the full spec page.
{% endcomment %}

{% liquid
  assign proxy_url = shop.url | append: '/apps/autosync'
  assign logo_url = 'autosync-logo.svg' | asset_url
  assign allowed_widgets_raw = shop.metafields['$app:autosync']['allowed_widgets'].value
  assign pages_allowed = false
  if allowed_widgets_raw != blank
    if allowed_widgets_raw.pages == true
      assign pages_allowed = true
    endif
  endif
%}
{% if pages_allowed == false %}
<!-- widget not available on current plan -->
{% else %}
<div
  class="autosync-vehicle-showcase"
  data-autosync-vehicle-showcase
  data-proxy-url="{{ proxy_url }}"
  data-show-logos="{{ block.settings.show_brand_logos | default: true }}"
  data-show-specs="{{ block.settings.show_spec_pills | default: true }}"
  data-per-page="{{ block.settings.vehicles_per_page | default: 18 }}"
  id="autosync-vehicle-showcase-{{ block.id }}"
  style="
--avs-primary: {{ block.settings.primary_color | default: '#005bd2' }};
--avs-bg: {{ block.settings.background_color | default: '#ffffff' }};
--avs-text: {{ block.settings.text_color | default: '#1a1a2e' }};
--avs-muted: {{ block.settings.muted_color | default: '#6b7280' }};
--avs-border: {{ block.settings.border_color | default: '#e5e7eb' }};
--avs-radius: {{ block.settings.border_radius | default: 8 }}px;
--avs-section-bg: {{ block.settings.section_bg | default: '#f9fafb' }};
--as-primary: {{ block.settings.primary_color | default: '#005bd2' }};
--as-bg: {{ block.settings.background_color | default: '#ffffff' }};
--as-text: {{ block.settings.text_color | default: '#1a1a2e' }};
--as-muted: {{ block.settings.muted_color | default: '#6b7280' }};
--as-border: {{ block.settings.border_color | default: '#e5e7eb' }};
--as-card-bg: {{ block.settings.section_bg | default: '#f9fafb' }};
--as-radius: {{ block.settings.border_radius | default: 8 }}px;
--as-btn-bg: {{ block.settings.button_color | default: block.settings.primary_color | default: '#005bd2' }};
--as-btn-text: {{ block.settings.button_text_color | default: '#ffffff' }};
    --as-section-gap: {{ block.settings.section_gap | default: 16 }}px;
--as-heading-size: {% case block.settings.heading_size %}{% when 'small' %}1.125rem{% when 'large' %}1.75rem{% else %}1.375rem{% endcase %};
padding-top: {{ block.settings.padding_top | default: 40 }}px;
padding-bottom: {{ block.settings.padding_bottom | default: 40 }}px;
max-width: {% if block.settings.container_width == 'full' %}100%{% else %}{{ block.settings.container_width | default: '1200' }}px{% endif %};
padding-left: {{ block.settings.container_padding | default: 16 }}px;
padding-right: {{ block.settings.container_padding | default: 16 }}px;
  "
>
  {% if block.settings.heading != blank %}
<h2 class="avs-heading" style="text-align: {{ block.settings.heading_alignment | default: 'center' }};">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.subheading != blank %}
<p class="avs-subheading" style="text-align: {{ block.settings.heading_alignment | default: 'center' }};">{{ block.settings.subheading }}</p>
  {% endif %}

  <!-- Search/Filter Bar -->
  {% if block.settings.show_search != false %}
  <div class="avs-filter" data-avs-filter>
<div class="avs-filter__search">
<svg class="avs-filter__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
<input type="text" class="avs-filter__input" data-avs-search placeholder="Search by make, model, fuel type..." />
</div>
<div class="avs-filter__count" data-avs-count></div>
  </div>
  {% endif %}

  <!-- Loading -->
  <div class="avs-loading" data-avs-loading>
<div class="avs-spinner"></div>
<p class="avs-loading__text">Loading vehicles...</p>
  </div>

  <!-- Empty State -->
  <div class="avs-empty" data-avs-empty style="display:none;">
<div class="avs-empty__icon-wrap">
<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.5 2.8C1.4 11.3 1 12.1 1 13v3c0 .6.4 1 1 1h1"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
</div>
<p class="avs-empty__title">No vehicle specification pages found.</p>
<p class="avs-empty__hint">Push vehicle pages from the AutoSync admin to populate this gallery.</p>
  </div>

  <!-- Vehicle Grid -->
  <div class="avs-grid" data-avs-grid data-columns="{{ block.settings.columns | default: 'auto' }}" style="display:none;"></div>

  <!-- Footer (hidden if merchant opted out via Settings > Widget Branding) -->
  {% unless shop.metafields['$app:autosync']['hide_watermark'].value == true %}
<div class="avs-footer">
<img class="avs-footer__logo" src="{{ logo_url }}" alt="AutoSync" width="14" height="14" style="width:14px!important;height:14px!important;max-width:14px!important;max-height:14px!important;" />
<span class="avs-footer__text">Powered by <strong>AutoSync</strong></span>
</div>
  {% endunless %}
</div>

{{ 'autosync-vehicle-gallery.css' | asset_url | stylesheet_tag }}

{{ "autosync-vehicle-gallery.js" | asset_url | script_tag }}
{% endif %}

{% schema %}
{
"name": "Vehicle Showcase",
"target": "section",
"templates": ["page", "article", "index", "collection"],
"settings": [
{
"type": "header",
"content": "Content"
},
{
"type": "text",
"id": "heading",
"label": "Heading",
"default": "Vehicle Specifications"
},
{
"type": "text",
"id": "subheading",
"label": "Subheading",
"default": "Browse detailed specs for all supported vehicles"
},
{
"type": "select",
"id": "heading_alignment",
"label": "Heading Alignment",
"options": [
{ "value": "left", "label": "Left" },
{ "value": "center", "label": "Center" }
],
"default": "center"
},
{
"type": "select",
"id": "heading_size",
"label": "Heading Size",
"options": [
{ "value": "small", "label": "Small" },
{ "value": "medium", "label": "Medium" },
{ "value": "large", "label": "Large" }
],
"default": "medium"
},
{
"type": "header",
"content": "Layout"
},
{
"type": "select",
"id": "container_width",
"label": "Container Width",
"options": [
{ "value": "full", "label": "Full Width" },
{ "value": "1400", "label": "Extra Wide (1400px)" },
{ "value": "1200", "label": "Standard (1200px)" },
{ "value": "1000", "label": "Narrow (1000px)" },
{ "value": "800", "label": "Compact (800px)" }
],
"default": "1200"
},
{
"type": "range",
"id": "container_padding",
"label": "Container Padding",
"min": 0,
"max": 60,
"step": 4,
"default": 16,
"unit": "px"
},
{
"type": "select",
"id": "columns",
"label": "Grid Columns",
"options": [
{ "value": "2", "label": "2 Columns" },
{ "value": "3", "label": "3 Columns" },
{ "value": "4", "label": "4 Columns" },
{ "value": "auto", "label": "Auto-fit" }
],
"default": "auto"
},
{
"type": "range",
"id": "vehicles_per_page",
"label": "Vehicles Per Page",
"min": 6,
"max": 48,
"step": 6,
"default": 18
},
{
"type": "range",
"id": "padding_top",
"label": "Top Padding",
"min": 0,
"max": 100,
"step": 4,
"default": 40,
"unit": "px"
},
{
"type": "range",
"id": "padding_bottom",
"label": "Bottom Padding",
"min": 0,
"max": 100,
"step": 4,
"default": 40,
"unit": "px"
},
{
"type": "range",
"id": "section_gap",
"label": "Bottom Margin (Gap Between Sections)",
"min": 0,
"max": 60,
"step": 4,
"default": 16,
"unit": "px"
},
{
"type": "range",
"id": "border_radius",
"label": "Border Radius",
"min": 0,
"max": 24,
"step": 2,
"default": 8,
"unit": "px"
},
{
"type": "header",
"content": "Colors"
},
{
"type": "color",
"id": "primary_color",
"label": "Primary Color",
"default": "#005bd2"
},
{
"type": "color",
"id": "background_color",
"label": "Background Color",
"default": "#ffffff"
},
{
"type": "color",
"id": "text_color",
"label": "Text Color",
"default": "#1a1a2e"
},
{
"type": "color",
"id": "muted_color",
"label": "Muted Text Color",
"default": "#6b7280"
},
{
"type": "color",
"id": "border_color",
"label": "Border Color",
"default": "#e5e7eb"
},
{
"type": "color",
"id": "section_bg",
"label": "Card Background",
"default": "#f9fafb"
},
{
"type": "color",
"id": "button_color",
"label": "Button Color",
"default": "#005bd2"
},
{
"type": "color",
"id": "button_text_color",
"label": "Button Text Color",
"default": "#ffffff"
},
{
"type": "header",
"content": "Features"
},
{
"type": "checkbox",
"id": "show_search",
"label": "Show Search Bar",
"default": true
},
{
"type": "checkbox",
"id": "show_brand_logos",
"label": "Show Brand Logos",
"default": true
},
{
"type": "checkbox",
"id": "show_spec_pills",
"label": "Show Spec Pills (HP, Displacement, Fuel)",
"default": true
}
]
}
{% endschema %}
