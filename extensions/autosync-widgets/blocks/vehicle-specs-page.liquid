{% comment %}
  AutoSync Vehicle Showcase
  Displays a browsable gallery of all vehicle specification pages.
  Add this block to any page (home, collection, custom page) to showcase
  all vehicles with fitment data. Each card links to the full spec page.
{% endcomment %}

{% liquid
  assign proxy_url = shop.url | append: '/apps/autosync'
%}

<div
  class="autosync-vehicle-showcase"
  data-autosync-vehicle-showcase
  data-proxy-url="{{ proxy_url }}"
  id="autosync-vehicle-showcase-{{ block.id }}"
  style="
    --avs-primary: {{ block.settings.primary_color | default: '#2563eb' }};
    --avs-bg: {{ block.settings.background_color | default: '#ffffff' }};
    --avs-text: {{ block.settings.text_color | default: '#1a1a2e' }};
    --avs-muted: {{ block.settings.muted_color | default: '#6b7280' }};
    --avs-border: {{ block.settings.border_color | default: '#e5e7eb' }};
    --avs-radius: {{ block.settings.border_radius | default: 10 }}px;
    --avs-section-bg: {{ block.settings.section_bg | default: '#f9fafb' }};
  "
>
  {% if block.settings.heading != blank %}
    <h2 class="avs-heading">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.subheading != blank %}
    <p class="avs-subheading">{{ block.settings.subheading }}</p>
  {% endif %}

  <!-- Search/Filter Bar -->
  <div class="avs-filter" data-avs-filter>
    <div class="avs-filter__search">
      <svg class="avs-filter__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" class="avs-filter__input" data-avs-search placeholder="Search vehicles..." />
    </div>
    <div class="avs-filter__count" data-avs-count></div>
  </div>

  <!-- Loading -->
  <div class="avs-loading" data-avs-loading>
    <div class="avs-spinner"></div>
    <p>Loading vehicles...</p>
  </div>

  <!-- Empty State -->
  <div class="avs-empty" data-avs-empty style="display:none;">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.5 2.8C1.4 11.3 1 12.1 1 13v3c0 .6.4 1 1 1h1"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
    <p>No vehicle specification pages found.</p>
    <p class="avs-empty__hint">Push vehicle pages from the AutoSync admin to populate this gallery.</p>
  </div>

  <!-- Vehicle Grid -->
  <div class="avs-grid" data-avs-grid style="display:none;"></div>
</div>

<style>
  .autosync-vehicle-showcase {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    color: var(--avs-text);
    background: var(--avs-bg);
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 16px;
  }

  .avs-heading {
    font-size: 28px;
    font-weight: 700;
    margin: 0 0 8px;
    text-align: center;
    letter-spacing: -0.02em;
  }
  .avs-subheading {
    font-size: 15px;
    color: var(--avs-muted);
    margin: 0 0 24px;
    text-align: center;
  }

  .avs-filter {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }
  .avs-filter__search {
    flex: 1;
    position: relative;
  }
  .avs-filter__icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--avs-muted);
    pointer-events: none;
  }
  .avs-filter__input {
    width: 100%;
    padding: 12px 14px 12px 42px;
    border: 1px solid var(--avs-border);
    border-radius: var(--avs-radius);
    font-size: 14px;
    background: var(--avs-section-bg);
    color: var(--avs-text);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }
  .avs-filter__input:focus {
    border-color: var(--avs-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--avs-primary) 15%, transparent);
  }
  .avs-filter__count {
    font-size: 13px;
    color: var(--avs-muted);
    white-space: nowrap;
    font-weight: 500;
  }

  .avs-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 60px 20px;
    gap: 12px;
    color: var(--avs-muted);
  }
  .avs-spinner {
    width: 28px; height: 28px;
    border: 3px solid var(--avs-border);
    border-top-color: var(--avs-primary);
    border-radius: 50%;
    animation: avs-spin 0.8s linear infinite;
  }
  @keyframes avs-spin { to { transform: rotate(360deg); } }

  .avs-empty {
    text-align: center;
    padding: 60px 20px;
    color: var(--avs-muted);
  }
  .avs-empty svg { margin: 0 auto 12px; display: block; }
  .avs-empty p { margin: 0 0 4px; font-size: 15px; }
  .avs-empty__hint { font-size: 13px; opacity: 0.7; }

  .avs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  .avs-card {
    background: var(--avs-section-bg);
    border: 1px solid var(--avs-border);
    border-radius: var(--avs-radius);
    padding: 20px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
    cursor: pointer;
  }
  .avs-card:hover {
    border-color: var(--avs-primary);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }
  .avs-card__header {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .avs-card__logo {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--avs-bg);
    border: 1px solid var(--avs-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 700;
    color: var(--avs-primary);
    flex-shrink: 0;
    text-transform: uppercase;
  }
  .avs-card__titles {
    flex: 1;
    min-width: 0;
  }
  .avs-card__make {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--avs-muted);
    font-weight: 600;
    margin: 0;
  }
  .avs-card__model {
    font-size: 16px;
    font-weight: 700;
    margin: 0;
    color: var(--avs-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .avs-card__variant {
    font-size: 13px;
    color: var(--avs-muted);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .avs-card__specs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .avs-card__tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
    background: var(--avs-bg);
    border: 1px solid var(--avs-border);
    color: var(--avs-text);
  }
  .avs-card__tag--primary {
    background: color-mix(in srgb, var(--avs-primary) 10%, transparent);
    border-color: color-mix(in srgb, var(--avs-primary) 25%, transparent);
    color: var(--avs-primary);
    font-weight: 600;
  }
  .avs-card__arrow {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    color: var(--avs-muted);
    transition: color 0.2s, transform 0.2s;
  }
  .avs-card:hover .avs-card__arrow {
    color: var(--avs-primary);
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .avs-grid {
      grid-template-columns: 1fr;
    }
    .avs-heading { font-size: 22px; }
    .avs-filter { flex-direction: column; align-items: stretch; }
    .avs-filter__count { text-align: right; }
  }
</style>

<script>
  (function() {
    var container = document.getElementById('autosync-vehicle-showcase-{{ block.id }}');
    if (!container) return;

    var proxyUrl = container.dataset.proxyUrl;
    var loadingEl = container.querySelector('[data-avs-loading]');
    var emptyEl = container.querySelector('[data-avs-empty]');
    var gridEl = container.querySelector('[data-avs-grid]');
    var searchInput = container.querySelector('[data-avs-search]');
    var countEl = container.querySelector('[data-avs-count]');
    var allVehicles = [];

    if (!proxyUrl) {
      showEmpty();
      return;
    }

    fetchGallery();

    function fetchGallery() {
      var url = new URL(proxyUrl);
      url.searchParams.set('path', 'vehicle-gallery');
      fetch(url.toString())
        .then(function(resp) {
          if (!resp.ok) throw new Error('Failed');
          return resp.json();
        })
        .then(function(data) {
          allVehicles = data.vehicles || [];
          if (allVehicles.length === 0) {
            showEmpty();
          } else {
            renderGrid(allVehicles);
          }
        })
        .catch(function() { showEmpty(); });
    }

    function showEmpty() {
      loadingEl.style.display = 'none';
      emptyEl.style.display = 'block';
      gridEl.style.display = 'none';
    }

    function renderGrid(vehicles) {
      loadingEl.style.display = 'none';
      emptyEl.style.display = 'none';
      gridEl.style.display = 'grid';
      gridEl.textContent = '';
      countEl.textContent = vehicles.length + ' vehicle' + (vehicles.length !== 1 ? 's' : '');

      vehicles.forEach(function(v) {
        var card = document.createElement('a');
        card.href = v.url;
        card.className = 'avs-card';

        // Header: logo + titles
        var header = document.createElement('div');
        header.className = 'avs-card__header';

        var logo = document.createElement('div');
        logo.className = 'avs-card__logo';
        logo.textContent = (v.make || '?').substring(0, 2);
        header.appendChild(logo);

        var titles = document.createElement('div');
        titles.className = 'avs-card__titles';

        var makeP = document.createElement('p');
        makeP.className = 'avs-card__make';
        makeP.textContent = v.make;
        titles.appendChild(makeP);

        var modelP = document.createElement('p');
        modelP.className = 'avs-card__model';
        modelP.textContent = v.model;
        titles.appendChild(modelP);

        header.appendChild(titles);
        card.appendChild(header);

        // Variant
        if (v.variant) {
          var variantP = document.createElement('p');
          variantP.className = 'avs-card__variant';
          variantP.textContent = v.variant;
          card.appendChild(variantP);
        }

        // Spec tags
        var specs = document.createElement('div');
        specs.className = 'avs-card__specs';

        if (v.powerHp) {
          var tag = document.createElement('span');
          tag.className = 'avs-card__tag avs-card__tag--primary';
          tag.textContent = v.powerHp + ' HP';
          specs.appendChild(tag);
        }
        if (v.displacement) {
          var tag2 = document.createElement('span');
          tag2.className = 'avs-card__tag';
          tag2.textContent = v.displacement;
          specs.appendChild(tag2);
        }
        if (v.fuelType) {
          var tag3 = document.createElement('span');
          tag3.className = 'avs-card__tag';
          tag3.textContent = v.fuelType;
          specs.appendChild(tag3);
        }
        card.appendChild(specs);

        // Arrow
        var arrow = document.createElement('div');
        arrow.className = 'avs-card__arrow';
        arrow.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg> <span style="font-size:13px;font-weight:500;margin-left:4px;">View Specs</span>';
        card.appendChild(arrow);

        gridEl.appendChild(card);
      });
    }

    // Search filter
    if (searchInput) {
      searchInput.addEventListener('input', function() {
        var q = searchInput.value.toLowerCase().trim();
        if (!q) {
          renderGrid(allVehicles);
          return;
        }
        var filtered = allVehicles.filter(function(v) {
          var text = (v.make + ' ' + v.model + ' ' + (v.variant || '') + ' ' + (v.fuelType || '') + ' ' + (v.displacement || '')).toLowerCase();
          return text.indexOf(q) !== -1;
        });
        if (filtered.length === 0) {
          gridEl.style.display = 'none';
          emptyEl.style.display = 'block';
          emptyEl.querySelector('p').textContent = 'No vehicles match "' + searchInput.value + '"';
          countEl.textContent = '0 vehicles';
        } else {
          emptyEl.style.display = 'none';
          renderGrid(filtered);
        }
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Vehicle Showcase",
  "target": "section",
  "templates": ["page", "article", "index", "collection"],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Vehicle Specifications"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Browse detailed specs for all supported vehicles"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#2563eb"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted Text Color",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#e5e7eb"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Background",
      "default": "#f9fafb"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 10,
      "unit": "px"
    }
  ]
}
{% endschema %}
