{% comment %}
  AutoSync Vehicle Showcase — Premium Gallery
  Displays a browsable gallery of all vehicle specification pages.
  Add this block to any page (home, collection, custom page) to showcase
  all vehicles with fitment data. Each card links to the full spec page.
{% endcomment %}

{% liquid
  assign proxy_url = shop.url | append: '/apps/autosync'
%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<div
  class="autosync-vehicle-showcase"
  data-autosync-vehicle-showcase
  data-proxy-url="{{ proxy_url }}"
  data-show-logos="{{ block.settings.show_brand_logos | default: true }}"
  data-show-specs="{{ block.settings.show_spec_pills | default: true }}"
  id="autosync-vehicle-showcase-{{ block.id }}"
  style="
    --avs-primary: {{ block.settings.primary_color | default: '#2563eb' }};
    --avs-bg: {{ block.settings.background_color | default: '#ffffff' }};
    --avs-text: {{ block.settings.text_color | default: '#1a1a2e' }};
    --avs-muted: {{ block.settings.muted_color | default: '#6b7280' }};
    --avs-border: {{ block.settings.border_color | default: '#e5e7eb' }};
    --avs-radius: {{ block.settings.border_radius | default: 12 }}px;
    --avs-section-bg: {{ block.settings.section_bg | default: '#f9fafb' }};
    padding-top: {{ block.settings.padding_top | default: 40 }}px;
    padding-bottom: {{ block.settings.padding_bottom | default: 40 }}px;
    max-width: {% if block.settings.container_width == 'full' %}100%{% else %}{{ block.settings.container_width | default: '1200' }}px{% endif %};
    padding-left: {{ block.settings.container_padding | default: 16 }}px;
    padding-right: {{ block.settings.container_padding | default: 16 }}px;
  "
>
  {% if block.settings.heading != blank %}
    <div class="avs-heading-wrap" style="text-align: {{ block.settings.heading_alignment | default: 'center' }};">
      <div class="avs-heading-accent" {% if block.settings.heading_alignment == 'left' %}style="margin-left: 0;"{% endif %}></div>
      <h2 class="avs-heading">{{ block.settings.heading }}</h2>
    </div>
  {% endif %}

  {% if block.settings.subheading != blank %}
    <p class="avs-subheading" style="text-align: {{ block.settings.heading_alignment | default: 'center' }};">{{ block.settings.subheading }}</p>
  {% endif %}

  <!-- Search/Filter Bar -->
  {% if block.settings.show_search != false %}
  <div class="avs-filter" data-avs-filter>
    <div class="avs-filter__search">
      <svg class="avs-filter__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" class="avs-filter__input" data-avs-search placeholder="Search by make, model, fuel type..." />
    </div>
    <div class="avs-filter__count" data-avs-count></div>
  </div>
  {% endif %}

  <!-- Loading -->
  <div class="avs-loading" data-avs-loading>
    <div class="avs-spinner"></div>
    <p class="avs-loading__text">Loading vehicles...</p>
  </div>

  <!-- Empty State -->
  <div class="avs-empty" data-avs-empty style="display:none;">
    <div class="avs-empty__icon-wrap">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.5 2.8C1.4 11.3 1 12.1 1 13v3c0 .6.4 1 1 1h1"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
    </div>
    <p class="avs-empty__title">No vehicle specification pages found.</p>
    <p class="avs-empty__hint">Push vehicle pages from the AutoSync admin to populate this gallery.</p>
  </div>

  <!-- Vehicle Grid -->
  <div class="avs-grid" data-avs-grid data-columns="{{ block.settings.columns | default: 'auto' }}" style="display:none;"></div>

  <!-- Footer -->
  <div class="avs-footer">
    <svg class="avs-footer__logo" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
    <span class="avs-footer__text">Powered by <strong>AutoSync</strong></span>
  </div>
</div>

{{ 'autosync-vehicle-gallery.css' | asset_url | stylesheet_tag }}

<script>
  (function() {
    var container = document.getElementById('autosync-vehicle-showcase-{{ block.id }}');
    if (!container) return;

    var proxyUrl = container.dataset.proxyUrl;
    var loadingEl = container.querySelector('[data-avs-loading]');
    var emptyEl = container.querySelector('[data-avs-empty]');
    var gridEl = container.querySelector('[data-avs-grid]');
    var searchInput = container.querySelector('[data-avs-search]');
    var countEl = container.querySelector('[data-avs-count]');
    var allVehicles = [];

    if (!proxyUrl) {
      showEmpty();
      return;
    }

    fetchGallery();

    function fetchGallery() {
      var url = new URL(proxyUrl);
      url.searchParams.set('path', 'vehicle-gallery');
      fetch(url.toString())
        .then(function(resp) {
          if (!resp.ok) throw new Error('Failed');
          return resp.json();
        })
        .then(function(data) {
          allVehicles = data.vehicles || [];
          if (allVehicles.length === 0) {
            showEmpty();
          } else {
            renderGrid(allVehicles);
          }
        })
        .catch(function() { showEmpty(); });
    }

    function showEmpty() {
      loadingEl.style.display = 'none';
      emptyEl.style.display = 'block';
      gridEl.style.display = 'none';
    }

    
    function svgEl(html) {
      var tmp = document.createElement('div');
      tmp.innerHTML = html;
      return tmp.firstChild;
    }

    function renderGrid(vehicles) {
      loadingEl.style.display = 'none';
      emptyEl.style.display = 'none';
      gridEl.style.display = 'grid';
      gridEl.textContent = '';

      var colsSetting = gridEl.getAttribute('data-columns') || 'auto';
      if (colsSetting === 'auto') {
        gridEl.style.gridTemplateColumns = 'repeat(auto-fill, minmax(280px, 1fr))';
      } else {
        gridEl.style.gridTemplateColumns = 'repeat(' + colsSetting + ', 1fr)';
      }

      var showLogos = container.getAttribute('data-show-logos') !== 'false';
      var showSpecs = container.getAttribute('data-show-specs') !== 'false';

      if (countEl) countEl.textContent = vehicles.length + ' vehicle' + (vehicles.length !== 1 ? 's' : '');

      vehicles.forEach(function(v, idx) {
        var card = document.createElement('a');
        card.href = v.url;
        card.className = 'avs-card';
        card.style.animationDelay = Math.min(idx * 0.04, 0.6) + 's';

        
        var header = document.createElement('div');
        header.className = 'avs-card__header';

        if (showLogos) {
          var logo = document.createElement('div');
          logo.className = 'avs-card__logo';

          if (v.logoUrl) {
            var img = document.createElement('img');
            img.src = v.logoUrl;
            img.alt = (v.make || '') + ' logo';
            img.loading = 'lazy';
            img.onerror = function() {
              
              this.parentNode.removeChild(this);
              var fb = document.createElement('span');
              fb.className = 'avs-card__logo-fallback';
              fb.textContent = (v.make || '??').substring(0, 2).toUpperCase();
              logo.appendChild(fb);
            };
            logo.appendChild(img);
          } else {
            var fallback = document.createElement('span');
            fallback.className = 'avs-card__logo-fallback';
            fallback.textContent = (v.make || '??').substring(0, 2).toUpperCase();
            logo.appendChild(fallback);
          }
          header.appendChild(logo);
        }

        var titles = document.createElement('div');
        titles.className = 'avs-card__titles';

        var makeP = document.createElement('p');
        makeP.className = 'avs-card__make';
        makeP.textContent = v.make || '';
        titles.appendChild(makeP);

        var modelP = document.createElement('p');
        modelP.className = 'avs-card__model';
        modelP.textContent = v.model || '';
        titles.appendChild(modelP);

        if (v.variant) {
          var variantP = document.createElement('p');
          variantP.className = 'avs-card__variant';
          variantP.textContent = v.variant;
          titles.appendChild(variantP);
        }

        header.appendChild(titles);
        card.appendChild(header);

        
        if (showSpecs) {
          var specs = document.createElement('div');
          specs.className = 'avs-card__specs';

          if (v.powerHp) {
            var pill1 = document.createElement('span');
            pill1.className = 'avs-card__pill avs-card__pill--power';
            pill1.appendChild(svgEl('<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>'));
            var pill1Text = document.createElement('span');
            pill1Text.textContent = v.powerHp + ' HP';
            pill1.appendChild(pill1Text);
            specs.appendChild(pill1);
          }
          if (v.displacement) {
            var pill2 = document.createElement('span');
            pill2.className = 'avs-card__pill';
            pill2.appendChild(svgEl('<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>'));
            var pill2Text = document.createElement('span');
            pill2Text.textContent = v.displacement;
            pill2.appendChild(pill2Text);
            specs.appendChild(pill2);
          }
          if (v.fuelType) {
            var pill3 = document.createElement('span');
            pill3.className = 'avs-card__pill';
            pill3.appendChild(svgEl('<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C12 2 7 8 7 13a5 5 0 0 0 10 0c0-5-5-11-5-11Z"/></svg>'));
            var pill3Text = document.createElement('span');
            pill3Text.textContent = v.fuelType;
            pill3.appendChild(pill3Text);
            specs.appendChild(pill3);
          }

          if (specs.childNodes.length > 0) {
            card.appendChild(specs);
          }
        }

        
        var footer = document.createElement('div');
        footer.className = 'avs-card__footer';

        var link = document.createElement('span');
        link.className = 'avs-card__link';
        var linkText = document.createElement('span');
        linkText.textContent = 'View Specs';
        link.appendChild(linkText);
        link.appendChild(svgEl('<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>'));
        footer.appendChild(link);

        card.appendChild(footer);
        gridEl.appendChild(card);
      });
    }

    
    if (searchInput) {
      var debounceTimer;
      searchInput.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(function() {
          var q = searchInput.value.toLowerCase().trim();
          if (!q) {
            renderGrid(allVehicles);
            return;
          }
          var filtered = allVehicles.filter(function(v) {
            var text = [v.make, v.model, v.variant, v.fuelType, v.displacement]
              .filter(Boolean).join(' ').toLowerCase();
            return text.indexOf(q) !== -1;
          });
          if (filtered.length === 0) {
            gridEl.style.display = 'none';
            emptyEl.style.display = 'block';
            var titleEl = emptyEl.querySelector('.avs-empty__title');
            if (titleEl) {
              titleEl.textContent = 'No vehicles match "' + searchInput.value + '"';
            }
            countEl.textContent = '0 vehicles';
          } else {
            emptyEl.style.display = 'none';
            renderGrid(filtered);
          }
        }, 150);
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Vehicle Showcase",
  "target": "section",
  "templates": ["page", "article", "index", "collection"],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Vehicle Specifications"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Browse detailed specs for all supported vehicles"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container Width",
      "options": [
        { "value": "full", "label": "Full Width" },
        { "value": "1400", "label": "Extra Wide (1400px)" },
        { "value": "1200", "label": "Standard (1200px)" },
        { "value": "1000", "label": "Narrow (1000px)" },
        { "value": "800", "label": "Compact (800px)" }
      ],
      "default": "1200"
    },
    {
      "type": "range",
      "id": "container_padding",
      "label": "Container Padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Grid Columns",
      "options": [
        { "value": "2", "label": "2 Columns" },
        { "value": "3", "label": "3 Columns" },
        { "value": "4", "label": "4 Columns" },
        { "value": "auto", "label": "Auto-fit" }
      ],
      "default": "auto"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show Search Bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_brand_logos",
      "label": "Show Brand Logos",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_spec_pills",
      "label": "Show Spec Pills (HP, Displacement, Fuel)",
      "default": true
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#2563eb"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted Text Color",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#e5e7eb"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Card Background",
      "default": "#f9fafb"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    }
  ]
}
{% endschema %}
