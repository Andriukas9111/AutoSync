{% comment %}
  AutoSync VIN Decode
  Enterprise-only feature — decodes a 17-character VIN via NHTSA API
{% endcomment %}

<div
  class="autosync-vin-decode"
  data-autosync-vin-decode
  data-proxy-url="{{ shop.url }}/apps/autosync"
  id="autosync-vin-decode-{{ block.id }}"
  style="padding-top: {{ block.settings.padding_top }}px; padding-bottom: {{ block.settings.padding_bottom }}px;"
>
  {% if block.settings.heading != blank %}
    <h2 class="autosync-vin-decode__heading">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="autosync-vin-decode__form">
    <div class="autosync-vin-decode__input-group">
      <input
        type="text"
        class="autosync-vin-decode__input"
        data-autosync-vin-input
        placeholder="{{ block.settings.placeholder_text | default: 'Enter 17-character VIN' }}"
        maxlength="17"
        autocomplete="off"
        spellcheck="false"
      />
    </div>
    <button type="button" class="autosync-vin-decode__btn" data-autosync-vin-submit>
      {{ block.settings.button_text | default: "Decode VIN" }}
    </button>
  </div>

  <div class="autosync-vin-decode__result autosync-vin-decode--hidden" data-autosync-vin-result>
    <div class="autosync-vin-decode__card">
      <h3 data-autosync-vin-vehicle-name></h3>
      <dl class="autosync-vin-decode__details">
        <dt>Body</dt><dd data-autosync-vin-body></dd>
        <dt>Drive</dt><dd data-autosync-vin-drive></dd>
        <dt>Engine</dt><dd data-autosync-vin-engine></dd>
        <dt>Fuel</dt><dd data-autosync-vin-fuel></dd>
        <dt>Transmission</dt><dd data-autosync-vin-transmission></dd>
        <dt>Trim</dt><dd data-autosync-vin-trim></dd>
        <dt>Manufacturer</dt><dd data-autosync-vin-manufacturer></dd>
        <dt>Origin</dt><dd data-autosync-vin-country></dd>
      </dl>
      <button type="button" class="autosync-vin-decode__find-parts autosync-vin-decode--hidden" data-autosync-vin-find-parts>
        Find Parts for This Vehicle
      </button>
    </div>
  </div>

  <div class="autosync-vin-decode__error autosync-vin-decode--hidden" data-autosync-vin-error>
    <p data-autosync-vin-error-msg></p>
  </div>
</div>

{{ 'autosync-widgets.css' | asset_url | stylesheet_tag }}
<script src="{{ 'autosync-widgets.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "VIN Decode",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Decode Your VIN"
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Placeholder Text",
      "default": "Enter 17-character VIN"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Decode VIN"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    }
  ]
}
{% endschema %}
