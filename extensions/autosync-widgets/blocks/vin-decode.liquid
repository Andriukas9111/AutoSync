{% comment %}
  AutoSync VIN Decode — Premium Edition
  Enterprise-only feature — decodes 17-char VIN via NHTSA API
  Features: live character counter, input validation, vehicle card, spec grid, compatible products
{% endcomment %}

{% liquid
  assign proxy_url = shop.url | append: '/apps/autosync'
%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

<div
  class="avd-root"
  data-avd-root
  data-proxy-url="{{ proxy_url }}"
  data-show-products="{{ block.settings.show_products | default: true }}"
  data-show-raw="{{ block.settings.show_raw_data | default: false }}"
  id="avd-{{ block.id }}"
  style="
    --avd-primary: {{ block.settings.primary_color | default: '#2563eb' }};
    --avd-accent: {{ block.settings.accent_color | default: '#8b5cf6' }};
    --avd-bg: {{ block.settings.background_color | default: '#ffffff' }};
    --avd-text: {{ block.settings.text_color | default: '#1a1a2e' }};
    --avd-muted: {{ block.settings.muted_color | default: '#6b7280' }};
    --avd-border: {{ block.settings.border_color | default: '#e5e7eb' }};
    --avd-card-bg: {{ block.settings.card_bg | default: '#f9fafb' }};
    --avd-radius: {{ block.settings.border_radius | default: 12 }}px;
    padding-top: {{ block.settings.padding_top | default: 40 }}px;
    padding-bottom: {{ block.settings.padding_bottom | default: 40 }}px;
    max-width: {% if block.settings.container_width == 'full' %}100%{% else %}{{ block.settings.container_width | default: '1200' }}px{% endif %};
    padding-left: {{ block.settings.container_padding | default: 24 }}px;
    padding-right: {{ block.settings.container_padding | default: 24 }}px;
  "
>
  {% if block.settings.heading != blank %}
    <div class="avd-heading-wrap" style="text-align: {{ block.settings.heading_alignment | default: 'center' }};">
      <div class="avd-heading-accent" {% if block.settings.heading_alignment == 'left' %}style="margin-left: 0;"{% endif %}></div>
      <h2 class="avd-heading">{{ block.settings.heading }}</h2>
    </div>
  {% endif %}

  {% if block.settings.subheading != blank %}
    <p class="avd-subheading" style="text-align: {{ block.settings.heading_alignment | default: 'center' }};">{{ block.settings.subheading }}</p>
  {% endif %}

  <!-- VIN Input -->
  <div class="avd-vin-form">
    <div class="avd-vin-input-wrap">
      <div class="avd-vin-badge">
        <svg class="avd-vin-badge__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        <span class="avd-vin-badge__text">VIN</span>
      </div>
      <input
        type="text"
        class="avd-vin-input"
        data-avd-input
        placeholder="{{ block.settings.placeholder_text | default: 'Enter 17-character VIN' }}"
        maxlength="17"
        autocomplete="off"
        spellcheck="false"
      />
      <span class="avd-vin-counter" data-avd-counter>0/17</span>
    </div>
    <button type="button" class="avd-submit-btn" data-avd-submit disabled>
      <svg class="avd-submit-btn__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <span>{{ block.settings.button_text | default: "Decode VIN" }}</span>
    </button>
  </div>

  <!-- Loading -->
  <div class="avd-loading" data-avd-loading style="display:none;">
    <div class="avd-spinner"></div>
    <p class="avd-loading__text">Decoding VIN...</p>
  </div>

  <!-- Error -->
  <div class="avd-error" data-avd-error style="display:none;">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
    <p class="avd-error__msg" data-avd-error-msg>Something went wrong.</p>
    <button type="button" class="avd-error__retry" data-avd-retry>Try Again</button>
  </div>

  <!-- Results (populated by JS) -->
  <div class="avd-results" data-avd-results style="display:none;"></div>
</div>

<style>
  .avd-root { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; color: var(--avd-text); background: var(--avd-bg); margin: 0 auto; -webkit-font-smoothing: antialiased; }
  .avd-root *, .avd-root *::before, .avd-root *::after { box-sizing: border-box; }
  .avd-heading-wrap { text-align: center; margin-bottom: 8px; }
  .avd-heading-accent { width: 48px; height: 4px; border-radius: 2px; background: linear-gradient(135deg, var(--avd-primary), var(--avd-accent)); margin: 0 auto 14px; }
  .avd-heading { font-size: 28px; font-weight: 800; margin: 0; letter-spacing: -0.03em; line-height: 1.2; background: linear-gradient(135deg, var(--avd-text) 0%, color-mix(in srgb, var(--avd-text) 70%, var(--avd-primary)) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .avd-subheading { font-size: 15px; color: var(--avd-muted); margin: 0 0 28px; font-weight: 400; line-height: 1.5; }
  .avd-vin-form { display: flex; gap: 12px; max-width: 600px; margin: 0 auto 32px; align-items: stretch; }
  .avd-vin-input-wrap { flex: 1; display: flex; position: relative; border: 2px solid var(--avd-border); border-radius: var(--avd-radius); background: var(--avd-bg); overflow: hidden; transition: border-color 0.25s ease, box-shadow 0.25s ease; }
  .avd-vin-input-wrap:focus-within { border-color: var(--avd-primary); box-shadow: 0 0 0 4px color-mix(in srgb, var(--avd-primary) 15%, transparent); }
  .avd-vin-badge { display: flex; align-items: center; gap: 4px; background: color-mix(in srgb, var(--avd-primary) 10%, transparent); padding: 0 12px; flex-shrink: 0; border-right: 1px solid var(--avd-border); }
  .avd-vin-badge__icon { color: var(--avd-primary); }
  .avd-vin-badge__text { font-size: 11px; font-weight: 800; color: var(--avd-primary); letter-spacing: 0.08em; }
  .avd-vin-input { flex: 1; border: none; outline: none; background: transparent; font-family: 'Inter', monospace; font-size: 17px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; padding: 14px 12px; color: var(--avd-text); min-width: 0; }
  .avd-vin-input::placeholder { color: var(--avd-muted); font-size: 14px; font-weight: 400; letter-spacing: 0; text-transform: none; opacity: 0.6; }
  .avd-vin-counter { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); font-size: 11px; font-weight: 600; color: var(--avd-muted); pointer-events: none; font-variant-numeric: tabular-nums; transition: color 0.2s; }
  .avd-vin-counter--valid { color: #10b981; }
  .avd-submit-btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border: none; border-radius: var(--avd-radius); background: var(--avd-primary); color: #fff; cursor: pointer; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700; transition: background 0.2s, transform 0.15s, box-shadow 0.2s; white-space: nowrap; }
  .avd-submit-btn:hover:not(:disabled) { background: color-mix(in srgb, var(--avd-primary) 85%, #000); transform: translateY(-1px); box-shadow: 0 4px 12px color-mix(in srgb, var(--avd-primary) 30%, transparent); }
  .avd-submit-btn:disabled { opacity: 0.45; cursor: not-allowed; transform: none; box-shadow: none; }
  .avd-loading { display: flex; flex-direction: column; align-items: center; padding: 48px 20px; gap: 14px; }
  .avd-spinner { width: 32px; height: 32px; border: 3px solid var(--avd-border); border-top-color: var(--avd-primary); border-radius: 50%; animation: avd-spin 0.7s linear infinite; }
  @keyframes avd-spin { to { transform: rotate(360deg); } }
  .avd-loading__text { font-size: 14px; color: var(--avd-muted); font-weight: 500; margin: 0; }
  .avd-error { text-align: center; padding: 48px 20px; color: var(--avd-muted); }
  .avd-error svg { margin: 0 auto 12px; display: block; }
  .avd-error__msg { margin: 0 0 16px; font-size: 14px; font-weight: 500; }
  .avd-error__retry { padding: 10px 24px; border: 1px solid var(--avd-border); border-radius: var(--avd-radius); background: var(--avd-bg); color: var(--avd-text); cursor: pointer; font-size: 13px; font-weight: 600; font-family: inherit; transition: border-color 0.2s, background 0.2s; }
  .avd-error__retry:hover { border-color: var(--avd-primary); background: var(--avd-card-bg); }

  /* Vehicle Card */
  .avd-vehicle-card { background: var(--avd-bg); border: 1px solid var(--avd-border); border-radius: calc(var(--avd-radius) + 4px); overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.04); max-width: 700px; margin: 0 auto; animation: avd-slideUp 0.35s ease both; }
  @keyframes avd-slideUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  .avd-vehicle-card__header { background: linear-gradient(135deg, #0a0f1e, #1a2744); color: #fff; padding: 28px 28px 24px; position: relative; }
  .avd-vehicle-card__header::after { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 80% 20%, rgba(99,102,241,0.15), transparent 60%); pointer-events: none; }
  .avd-vehicle-card__vin-tag { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.15); border-radius: 6px; padding: 5px 12px; margin-bottom: 12px; font-family: 'Inter', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.06em; color: rgba(255,255,255,0.85); backdrop-filter: blur(8px); }
  .avd-vehicle-card__vin-tag svg { opacity: 0.7; }
  .avd-vehicle-card__title { font-size: 26px; font-weight: 800; margin: 0 0 4px; letter-spacing: -0.02em; position: relative; z-index: 1; }
  .avd-vehicle-card__subtitle { font-size: 14px; color: rgba(255,255,255,0.6); margin: 0 0 14px; font-weight: 400; position: relative; z-index: 1; }
  .avd-vehicle-card__badges { display: flex; flex-wrap: wrap; gap: 6px; position: relative; z-index: 1; }
  .avd-badge { display: inline-flex; align-items: center; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; letter-spacing: 0.03em; text-transform: uppercase; }
  .avd-badge--accent { background: rgba(139,92,246,0.2); color: #c4b5fd; border: 1px solid rgba(139,92,246,0.3); }
  .avd-badge--primary { background: rgba(59,130,246,0.2); color: #93c5fd; border: 1px solid rgba(59,130,246,0.3); }
  .avd-badge--muted { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.7); border: 1px solid rgba(255,255,255,0.12); }

  /* Spec Grid */
  .avd-spec-section { padding: 24px 28px; }
  .avd-spec-section__title { font-size: 13px; font-weight: 700; color: var(--avd-muted); text-transform: uppercase; letter-spacing: 0.06em; margin: 0 0 16px; display: flex; align-items: center; gap: 8px; }
  .avd-spec-section__title svg { color: var(--avd-primary); opacity: 0.7; }
  .avd-spec-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0; border: 1px solid var(--avd-border); border-radius: var(--avd-radius); overflow: hidden; }
  .avd-spec-item { padding: 14px 16px; border-bottom: 1px solid var(--avd-border); border-right: 1px solid var(--avd-border); background: var(--avd-bg); }
  .avd-spec-item:nth-child(even) { border-right: none; }
  .avd-spec-item:nth-last-child(-n+2) { border-bottom: none; }
  .avd-spec-item__label { font-size: 11px; font-weight: 600; color: var(--avd-muted); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 4px; }
  .avd-spec-item__value { font-size: 14px; font-weight: 700; color: var(--avd-text); }

  /* Products Grid */
  .avd-products-section { padding: 0 28px 24px; }
  .avd-products-section__title { font-size: 13px; font-weight: 700; color: var(--avd-muted); text-transform: uppercase; letter-spacing: 0.06em; margin: 0 0 14px; display: flex; align-items: center; gap: 8px; }
  .avd-products-section__title svg { color: var(--avd-primary); opacity: 0.7; }
  .avd-products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .avd-product-card { background: var(--avd-card-bg); border: 1px solid var(--avd-border); border-radius: var(--avd-radius); padding: 12px; text-decoration: none; color: var(--avd-text); transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s; display: flex; flex-direction: column; }
  .avd-product-card:hover { border-color: var(--avd-primary); box-shadow: 0 4px 12px color-mix(in srgb, var(--avd-primary) 10%, transparent); transform: translateY(-2px); }
  .avd-product-card__img { width: 100%; aspect-ratio: 1; object-fit: contain; border-radius: calc(var(--avd-radius) - 4px); background: #fff; margin-bottom: 8px; }
  .avd-product-card__name { font-size: 12px; font-weight: 600; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 4px; }
  .avd-product-card__price { font-size: 13px; font-weight: 700; color: var(--avd-primary); }

  /* Footer */
  .avd-footer { display: flex; align-items: center; justify-content: center; gap: 6px; padding: 16px 28px 20px; border-top: 1px solid var(--avd-border); }
  .avd-footer__text { font-size: 11px; font-weight: 500; color: var(--avd-muted); opacity: 0.6; }
  .avd-footer svg { opacity: 0.4; }

  /* Divider */
  .avd-divider { height: 1px; background: var(--avd-border); margin: 0; }

  /* Responsive */
  @media (max-width: 640px) {
    .avd-vin-form { flex-direction: column; }
    .avd-vin-input { font-size: 15px; letter-spacing: 0.08em; }
    .avd-vehicle-card__title { font-size: 22px; }
    .avd-spec-grid { grid-template-columns: 1fr; }
    .avd-spec-item { border-right: none; }
    .avd-spec-item:last-child { border-bottom: none; }
    .avd-products-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  }
</style>

<script>
(function() {
  var root = document.getElementById('avd-{{ block.id }}');
  if (!root) return;

  var proxyUrl = root.dataset.proxyUrl;
  var showProducts = root.dataset.showProducts !== 'false';
  var loadingEl = root.querySelector('[data-avd-loading]');
  var errorEl = root.querySelector('[data-avd-error]');
  var resultsEl = root.querySelector('[data-avd-results]');
  var input = root.querySelector('[data-avd-input]');
  var counter = root.querySelector('[data-avd-counter]');
  var submitBtn = root.querySelector('[data-avd-submit]');
  var retryBtn = root.querySelector('[data-avd-retry]');
  var btnLabel = submitBtn ? submitBtn.querySelector('span') : null;
  var lastVin = '';

  if (!input || !submitBtn) return;

  /* Input validation: uppercase, remove I/O/Q (invalid VIN chars) */
  input.addEventListener('input', function() {
    this.value = this.value.toUpperCase().replace(/[^A-HJ-NPR-Z0-9]/g, '');
    var len = this.value.length;
    if (counter) {
      counter.textContent = len + '/17';
      counter.className = 'avd-vin-counter' + (len === 17 ? ' avd-vin-counter--valid' : '');
    }
    submitBtn.disabled = len !== 17;
  });

  input.addEventListener('keydown', function(e) { if (e.key === 'Enter' && !submitBtn.disabled) submitBtn.click(); });
  if (retryBtn) retryBtn.addEventListener('click', function() { if (lastVin) doDecode(lastVin); });

  submitBtn.addEventListener('click', function() {
    var vin = input.value.trim();
    if (vin.length !== 17) return;
    lastVin = vin;
    doDecode(vin);
  });

  function doDecode(vin) {
    submitBtn.disabled = true;
    if (btnLabel) btnLabel.textContent = 'Decoding...';
    loadingEl.style.display = 'flex';
    errorEl.style.display = 'none';
    resultsEl.style.display = 'none';

    fetch(proxyUrl + '?path=vin-decode', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ vin: vin }),
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        loadingEl.style.display = 'none';
        submitBtn.disabled = false;
        if (btnLabel) btnLabel.textContent = 'Decode VIN';
        if (data.error) { showError(data.error); return; }
        if (data.vehicle) renderResults(data.vehicle, data.compatibleProducts || [], vin);
      })
      .catch(function() {
        loadingEl.style.display = 'none';
        submitBtn.disabled = false;
        if (btnLabel) btnLabel.textContent = 'Decode VIN';
        showError('Failed to decode VIN. Please check and try again.');
      });
  }

  function showError(msg) {
    var msgEl = errorEl.querySelector('[data-avd-error-msg]');
    if (msgEl) msgEl.textContent = msg;
    errorEl.style.display = 'block';
    resultsEl.style.display = 'none';
  }

  function el(tag, className, text) {
    var e = document.createElement(tag);
    if (className) e.className = className;
    if (text !== undefined && text !== null) e.textContent = String(text);
    return e;
  }

  /* Static SVG helper — only for known safe static icon strings */
  function svgIcon(markup) {
    var t = document.createElement('template');
    t.innerHTML = markup.trim();
    return t.content.firstChild;
  }

  var ICONS = {
    code: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
    specs: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>',
    products: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>',
    logo: '<svg width="20" height="20" viewBox="0 0 1200 1200" fill="none"><path fill="currentColor" d="M475.97,954.05l1.15-2.09c.26-.47.74-1.38.9-1.88,3.43-2.52,6.07-7.05,5.08-11.15.27-.44.68-1.39.85-1.87,3.7-2.85,6.29-7.47,6.15-12.07.3-.43.61-1.46.86-1.93l2.59-1.43c.75-.41.14-2.37-.47-2.71l.87-1.86,2.58-1.38c.75-.4.05-2.55-.44-2.87.23-.45.77-1.24,1.07-1.69,2-1.41,3.82-4.02,2.99-6.2l.79-1.86,2.64-1.4c.76-.41.1-2.42-.52-2.74l.87-1.86,2.5-1.27c.72-.37-.15-2.16-.37-2.88.23-.76.59-2.16.93-2.82,4.78-3.57,19-34.98,21.07-40.92.09-.25-.15-.79-.03-1.03,2.43-1.98,3.74-4.54,5.38-7.85l46.96-94.81c1.69-3.41,2.79-6.31,2.73-9.53,10.04-20.44,16.99-42.51,29.07-62.04,1.51-.81,2.45-3.2,2.96-4.78.18-.57.81-1.61,1.07-2.17,4.55-3.53,6.73-9.47,9.88-14.92,2.97-5.15,7.64-9.61,7.93-15.01.6-.88,1.65-2.22,2.17-3.08,2.18-1.23,4.45-3.6,3.83-5.93.56-.79,1.83-2.17,2.12-3.05,3.84-2.5,5.83-6.93,7.75-11.18,9.67-13.7,19.34-27.27,30.77-39.85l19.64-21.62c9.69-10.67,18.68-20.01,29.53-29.6l19.62-17.35,31.01-25.01c3.32-2.68,8.39-6.65,5.99-11.54l-25.43-51.94-75.53-151.3-67.09-134.73c-4.27-8.57-13.25-13.64-21.47-14.59-8.62-1-21.01,1.61-25.31,10.39l-47.54,96.96-13.24,28.33-80.24,165.62-48.41,99.53-250.39,517.49c-4.44,9.18-7.86,15.46-5.58,27.17,2.52,13,18.9,25.22,34.53,19.43l297.19-110.08c8.82-3.27,14-9.71,18.05-17.06Z"/><path fill="currentColor" d="M728.87,955.34c4.84,9.54,10.97,15.02,20.54,18.57l289.84,107.29c10.02,3.71,21.67-.68,27.65-6.95s11.2-18.55,6.35-28.37l-69.4-140.74-123.43-248.48-41.65-84.41-36.42-72.5c-.98-1.95-3.81-4.07-5.45-4.64s-5.59.13-7.09,1.43c-13.12,11.34-37.55,39.1-48.25,53.11-47.54,62.24-86.7,138.7-92.9,217.9-.78,9.91-3.53,20.04.33,29.51,6.35,15.6,14.58,29.51,22.26,44.66l57.62,113.62Z"/></svg>'
  };

  function renderResults(vehicle, products, vin) {
    while (resultsEl.firstChild) resultsEl.removeChild(resultsEl.firstChild);

    var card = el('div', 'avd-vehicle-card');

    /* Header */
    var header = el('div', 'avd-vehicle-card__header');
    var vinTag = el('div', 'avd-vehicle-card__vin-tag');
    vinTag.appendChild(svgIcon(ICONS.code));
    vinTag.appendChild(document.createTextNode(vin));
    header.appendChild(vinTag);

    var title = (vehicle.make || '') + ' ' + (vehicle.model || '');
    header.appendChild(el('h2', 'avd-vehicle-card__title', title.trim() || 'Unknown Vehicle'));

    var subtitleParts = [];
    if (vehicle.modelYear) subtitleParts.push(vehicle.modelYear);
    if (vehicle.trim) subtitleParts.push(vehicle.trim);
    if (vehicle.plantCountry) subtitleParts.push(vehicle.plantCountry);
    if (subtitleParts.length) header.appendChild(el('p', 'avd-vehicle-card__subtitle', subtitleParts.join(' \u2022 ')));

    /* Badges */
    var badges = el('div', 'avd-vehicle-card__badges');
    if (vehicle.fuelType) { var b = el('span', 'avd-badge avd-badge--accent', vehicle.fuelType); badges.appendChild(b); }
    if (vehicle.bodyClass) { var b2 = el('span', 'avd-badge avd-badge--primary', vehicle.bodyClass); badges.appendChild(b2); }
    if (vehicle.driveType) { var b3 = el('span', 'avd-badge avd-badge--muted', vehicle.driveType); badges.appendChild(b3); }
    if (vehicle.transmissionStyle) { var b4 = el('span', 'avd-badge avd-badge--muted', vehicle.transmissionStyle); badges.appendChild(b4); }
    if (badges.childNodes.length) header.appendChild(badges);

    card.appendChild(header);

    /* Spec Grid */
    var specSection = el('div', 'avd-spec-section');
    var specTitle = el('div', 'avd-spec-section__title');
    specTitle.appendChild(svgIcon(ICONS.specs));
    specTitle.appendChild(document.createTextNode('Vehicle Specifications'));
    specSection.appendChild(specTitle);

    var grid = el('div', 'avd-spec-grid');
    var specs = [
      ['Model Year', vehicle.modelYear],
      ['Body Style', vehicle.bodyClass],
      ['Drive Type', vehicle.driveType],
      ['Fuel Type', vehicle.fuelType],
      ['Cylinders', vehicle.engineCylinders],
      ['Displacement', vehicle.engineDisplacement ? vehicle.engineDisplacement + ' L' : null],
      ['Transmission', vehicle.transmissionStyle],
      ['Manufacturer', vehicle.manufacturer],
      ['Country of Origin', vehicle.plantCountry],
      ['Trim', vehicle.trim]
    ];

    var addedCount = 0;
    for (var i = 0; i < specs.length; i++) {
      if (specs[i][1]) {
        var item = el('div', 'avd-spec-item');
        item.appendChild(el('div', 'avd-spec-item__label', specs[i][0]));
        item.appendChild(el('div', 'avd-spec-item__value', String(specs[i][1])));
        grid.appendChild(item);
        addedCount++;
      }
    }

    /* Ensure even number of grid items for clean layout */
    if (addedCount % 2 !== 0) {
      var spacer = el('div', 'avd-spec-item');
      spacer.style.background = 'transparent';
      spacer.style.borderRight = 'none';
      grid.appendChild(spacer);
    }

    specSection.appendChild(grid);
    card.appendChild(specSection);

    /* Compatible Products */
    if (showProducts && products.length > 0) {
      card.appendChild(el('div', 'avd-divider'));

      var prodsSection = el('div', 'avd-products-section');
      var prodsTitle = el('div', 'avd-products-section__title');
      prodsTitle.appendChild(svgIcon(ICONS.products));
      prodsTitle.appendChild(document.createTextNode('Compatible Products (' + products.length + ')'));
      prodsSection.appendChild(prodsTitle);

      var prodsGrid = el('div', 'avd-products-grid');
      var maxProds = Math.min(products.length, 12);
      for (var j = 0; j < maxProds; j++) {
        var p = products[j];
        var a = document.createElement('a');
        a.className = 'avd-product-card';
        a.href = p.url || '#';
        if (p.image) {
          var img = document.createElement('img');
          img.className = 'avd-product-card__img';
          img.src = p.image;
          img.alt = p.title || '';
          img.loading = 'lazy';
          a.appendChild(img);
        }
        a.appendChild(el('div', 'avd-product-card__name', p.title || 'Product'));
        if (p.price) a.appendChild(el('div', 'avd-product-card__price', p.price));
        prodsGrid.appendChild(a);
      }
      prodsSection.appendChild(prodsGrid);
      card.appendChild(prodsSection);
    }

    /* Footer */
    var footer = el('div', 'avd-footer');
    footer.appendChild(svgIcon(ICONS.logo));
    footer.appendChild(el('span', 'avd-footer__text', 'Powered by AutoSync'));
    card.appendChild(footer);

    resultsEl.appendChild(card);
    resultsEl.style.display = 'block';

    /* Store decoded vehicle for fitment badge cross-referencing */
    try {
      var stored = { make: vehicle.make, model: vehicle.model, year: vehicle.modelYear, source: 'vin' };
      localStorage.setItem('autosync_vehicle', JSON.stringify(stored));
    } catch(e) {}
  }
})();
</script>

