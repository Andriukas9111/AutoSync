{% liquid
  assign proxy_url = shop.url | append: '/apps/autosync'
  assign logo_url = 'autosync-logo.svg' | asset_url
  assign allowed_widgets_raw = shop.metafields['$app:autosync']['allowed_widgets'].value
  assign vin_allowed = false
  if allowed_widgets_raw != blank
    if allowed_widgets_raw.vin == true
      assign vin_allowed = true
    endif
  endif
%}
{% if vin_allowed == false %}
<!-- widget not available on current plan -->
{% else %}
<div
  class="avd-root"
  data-avd-root
  data-proxy-url="{{ proxy_url }}"
  data-logo-url="{{ logo_url }}"
  data-hide-watermark="{{ shop.metafields['$app:autosync']['hide_watermark'].value | default: false }}"
  data-show-products="{{ block.settings.show_products | default: true }}"
  data-show-raw="{{ block.settings.show_raw_data | default: false }}"
  data-result-style="{{ block.settings.result_style | default: 'compact' }}"
  data-content-position="{{ block.settings.content_position | default: 'left' }}"
  data-heading="{{ block.settings.heading | escape }}"
  data-subheading="{{ block.settings.subheading | escape }}"
  data-description="{{ block.settings.description_text | escape }}"
  id="avd-{{ block.id }}"
  style="
    --avd-primary: {{ block.settings.primary_color | default: '#005bd2' }};
    --avd-bg: {{ block.settings.background_color | default: '#ffffff' }};
    --avd-text: {{ block.settings.text_color | default: '#1a1a2e' }};
    --avd-muted: {{ block.settings.muted_color | default: '#6b7280' }};
    --avd-border: {{ block.settings.border_color | default: '#e5e7eb' }};
    --avd-card-bg: {{ block.settings.card_bg | default: '#f9fafb' }};
    --avd-radius: {{ block.settings.border_radius | default: 8 }}px;
    --as-primary: {{ block.settings.primary_color | default: '#005bd2' }};
    --as-bg: {{ block.settings.background_color | default: '#ffffff' }};
    --as-text: {{ block.settings.text_color | default: '#1a1a2e' }};
    --as-muted: {{ block.settings.muted_color | default: '#6b7280' }};
    --as-border: {{ block.settings.border_color | default: '#e5e7eb' }};
    --as-card-bg: {{ block.settings.card_bg | default: '#f9fafb' }};
    --as-radius: {{ block.settings.border_radius | default: 8 }}px;
    --as-btn-bg: {{ block.settings.button_color | default: block.settings.primary_color | default: '#005bd2' }};
    --as-btn-text: {{ block.settings.button_text_color | default: '#ffffff' }};
    --as-section-gap: {{ block.settings.section_gap | default: 16 }}px;
    --as-section-gap-top: {{ block.settings.section_gap_top | default: 0 }}px;
    --as-heading-size: {% case block.settings.heading_size %}{% when 'small' %}18px{% when 'large' %}28px{% else %}22px{% endcase %};
    padding-top: {{ block.settings.padding_top | default: 40 }}px;
    padding-bottom: {{ block.settings.padding_bottom | default: 40 }}px;
    max-width: {% if block.settings.container_width == 'full' %}100%{% else %}{{ block.settings.container_width | default: '1200' }}px{% endif %};
    padding-left: {{ block.settings.container_padding | default: 24 }}px;
    padding-right: {{ block.settings.container_padding | default: 24 }}px;
  "
>
  <div class="avd-container">
    <!-- Text content side -->
    <div class="avd-content" data-avd-content>
      {% if block.settings.heading != blank %}
        <h2 class="avd-heading">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="avd-subheading">{{ block.settings.subheading }}</p>
      {% endif %}
      {% if block.settings.description_text != blank %}
        <p class="avd-description">{{ block.settings.description_text }}</p>
      {% endif %}
    </div>

    <!-- Form side -->
    <div class="avd-form-side" data-avd-form-side>
      <div class="avd-vin-form">
        <div class="avd-vin-input-wrap">
          <input
            type="text"
            class="avd-vin-input"
            data-avd-input
            placeholder="{{ block.settings.placeholder_text | default: 'Enter 17-character VIN' }}"
            maxlength="17"
            autocomplete="off"
            spellcheck="false"
            aria-label="Vehicle Identification Number"
          />
          <span class="avd-vin-counter" data-avd-counter>0/17</span>
        </div>
        <button type="button" class="avd-submit-btn" data-avd-submit disabled>
          <svg class="avd-submit-btn__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <span>{{ block.settings.button_text | default: "Decode VIN" }}</span>
        </button>
      </div>
    </div>
  </div>

  <div class="avd-loading" data-avd-loading style="display:none;">
    <div class="avd-spinner"></div>
    <p class="avd-loading__text">Decoding VIN...</p>
  </div>

  <div class="avd-error" data-avd-error style="display:none;">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
    <p class="avd-error__msg" data-avd-error-msg>Something went wrong.</p>
    <button type="button" class="avd-error__retry" data-avd-retry>Try Again</button>
  </div>

  <div class="avd-results" data-avd-results style="display:none;"></div>
</div>

{{ 'autosync-vin-decode.css' | asset_url | stylesheet_tag }}

<script src="{{ "autosync-vin-decode.js" | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
"name": "VIN Decode",
"target": "section",
"settings": [
{
"type": "header",
"content": "Content"
},
{
"type": "text",
"id": "heading",
"label": "Heading",
"default": "Decode Your VIN"
},
{
"type": "text",
"id": "subheading",
"label": "Subheading",
"default": "Instant vehicle specs and compatible parts"
},
{
"type": "textarea",
"id": "description_text",
"label": "Description Text",
"default": "Enter your 17-character Vehicle Identification Number for instant vehicle specs, compatibility check, and matching parts."
},
{
"type": "text",
"id": "placeholder_text",
"label": "Input Placeholder",
"default": "Enter 17-character VIN"
},
{
"type": "text",
"id": "button_text",
"label": "Button Text",
"default": "Decode VIN"
},
{
"type": "select",
"id": "content_position",
"label": "Text Position",
"options": [
{ "value": "left", "label": "Left" },
{ "value": "right", "label": "Right" }
],
"default": "left"
},
{
"type": "select",
"id": "heading_alignment",
"label": "Heading Alignment",
"options": [
{ "value": "left", "label": "Left" },
{ "value": "center", "label": "Center" }
],
"default": "left"
},
{
"type": "select",
"id": "heading_size",
"label": "Heading Size",
"options": [
{ "value": "small", "label": "Small" },
{ "value": "medium", "label": "Medium" },
{ "value": "large", "label": "Large" }
],
"default": "medium"
},
{
"type": "header",
"content": "Features"
},
{
"type": "checkbox",
"id": "show_products",
"label": "Show compatible products",
"default": true
},
{
"type": "checkbox",
"id": "show_raw_data",
"label": "Show raw decoded data",
"default": false
},
{
"type": "select",
"id": "result_style",
"label": "Result Display",
"options": [
{ "value": "compact", "label": "Compact Bar (Recommended)" },
{ "value": "expanded", "label": "Full Card (Classic)" }
],
"default": "compact"
},
{
"type": "header",
"content": "Colors"
},
{
"type": "color",
"id": "primary_color",
"label": "Primary Color",
"default": "#005bd2"
},
{
"type": "color",
"id": "background_color",
"label": "Background",
"default": "#ffffff"
},
{
"type": "color",
"id": "text_color",
"label": "Text Color",
"default": "#1a1a2e"
},
{
"type": "color",
"id": "muted_color",
"label": "Muted Text Color",
"default": "#6b7280"
},
{
"type": "color",
"id": "border_color",
"label": "Border Color",
"default": "#e5e7eb"
},
{
"type": "color",
"id": "card_bg",
"label": "Card Background",
"default": "#f9fafb"
},
{
"type": "color",
"id": "button_color",
"label": "Button Color",
"default": "#005bd2"
},
{
"type": "color",
"id": "button_text_color",
"label": "Button Text Color",
"default": "#ffffff"
},
{
"type": "header",
"content": "Layout"
},
{
"type": "select",
"id": "container_width",
"label": "Container Width",
"options": [
{ "value": "800", "label": "Narrow (800px)" },
{ "value": "1000", "label": "Medium (1000px)" },
{ "value": "1200", "label": "Wide (1200px)" },
{ "value": "1400", "label": "Extra Wide (1400px)" },
{ "value": "full", "label": "Full Width" }
],
"default": "1200"
},
{
"type": "range",
"id": "container_padding",
"label": "Side Padding",
"min": 0,
"max": 60,
"step": 4,
"default": 24,
"unit": "px"
},
{
"type": "range",
"id": "border_radius",
"label": "Border Radius",
"min": 0,
"max": 24,
"step": 2,
"default": 8,
"unit": "px"
},
{
"type": "range",
"id": "padding_top",
"label": "Top Padding",
"min": 0,
"max": 100,
"step": 4,
"default": 40,
"unit": "px"
},
{
"type": "range",
"id": "padding_bottom",
"label": "Bottom Padding",
"min": 0,
"max": 100,
"step": 4,
"default": 40,
"unit": "px"
},
{
"type": "range",
"id": "section_gap",
"label": "Bottom Margin (Gap Between Sections)",
"min": 0,
"max": 60,
"step": 4,
"default": 16,
"unit": "px"
},
{
"type": "range",
"id": "section_gap_top",
"label": "Top Margin (Gap Above Section)",
"min": 0,
"max": 60,
"step": 4,
"default": 0,
"unit": "px"
}
]
}
{% endschema %}
