{% comment %}
  AutoSync Wheel Finder
  Search wheels by PCD, offset, and diameter
{% endcomment %}
{% liquid
  assign allowed_widgets_raw = shop.metafields['$app:autosync']['allowed_widgets'].value
  assign wheel_allowed = false
  if allowed_widgets_raw != blank
    if allowed_widgets_raw.wheel == true
      assign wheel_allowed = true
    endif
  endif
%}
{% if wheel_allowed == false %}
<!-- widget not available on current plan -->
{% else %}
<div
  class="autosync-wheel-finder"
  data-autosync-wheel-finder
  data-proxy-url="{{ shop.url }}/apps/autosync"
  data-currency-symbol="{{ cart.currency.symbol }}"
  data-currency-code="{{ cart.currency.iso_code }}"
  data-hide-watermark="{{ shop.metafields['$app:autosync']['hide_watermark'].value | default: false }}"
  id="autosync-wheel-finder-{{ block.id }}"
  style="
    --awf-primary: {{ block.settings.primary_color | default: '#005bd2' }};
    --awf-bg: {{ block.settings.background_color | default: '#ffffff' }};
    --awf-text: {{ block.settings.text_color | default: '#1a1a2e' }};
    --awf-muted: {{ block.settings.muted_color | default: '#6b7280' }};
    --awf-border: {{ block.settings.border_color | default: '#e5e7eb' }};
    --awf-card-bg: {{ block.settings.card_bg | default: '#f9fafb' }};
    --awf-radius: {{ block.settings.border_radius | default: 10 }}px;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    max-width: {% if block.settings.container_width == 'full' %}100%{% else %}{{ block.settings.container_width | default: '1200' }}px{% endif %};
    margin: 0 auto;
  "
>
  {% if block.settings.heading != blank %}
    <h2 class="autosync-wheel-finder__heading" style="text-align: {{ block.settings.heading_alignment | default: 'center' }};">{{ block.settings.heading }}</h2>
  {% endif %}
  {% if block.settings.subheading != blank %}
    <p class="autosync-wheel-finder__subheading" style="text-align: {{ block.settings.heading_alignment | default: 'center' }};">{{ block.settings.subheading }}</p>
  {% endif %}

  <div class="autosync-wheel-finder__fields">
    <div class="autosync-wheel-finder__field">
      <label for="autosync-pcd-{{ block.id }}">PCD (Bolt Pattern)</label>
      <select id="autosync-pcd-{{ block.id }}" data-autosync-wheel-pcd>
        <option value="">Select PCD</option>
        <option value="4x100">4x100</option>
        <option value="4x108">4x108</option>
        <option value="4x114.3">4x114.3</option>
        <option value="5x100">5x100</option>
        <option value="5x108">5x108</option>
        <option value="5x112">5x112</option>
        <option value="5x114.3">5x114.3</option>
        <option value="5x120">5x120</option>
        <option value="5x130">5x130</option>
      </select>
    </div>

    <div class="autosync-wheel-finder__field">
      <label for="autosync-diameter-{{ block.id }}">Diameter</label>
      <select id="autosync-diameter-{{ block.id }}" data-autosync-wheel-diameter>
        <option value="">Select Diameter</option>
        <option value="15">15"</option>
        <option value="16">16"</option>
        <option value="17">17"</option>
        <option value="18">18"</option>
        <option value="19">19"</option>
        <option value="20">20"</option>
        <option value="21">21"</option>
        <option value="22">22"</option>
      </select>
    </div>

    <div class="autosync-wheel-finder__field">
      <label for="autosync-offset-{{ block.id }}">Offset (ET)</label>
      <input
        type="number"
        id="autosync-offset-{{ block.id }}"
        data-autosync-wheel-offset
        placeholder="e.g. 35"
        min="-30"
        max="60"
      />
    </div>

    <div class="autosync-wheel-finder__field autosync-wheel-finder__field--button">
      <button type="button" data-autosync-wheel-search>
        {{ block.settings.button_text | default: "Search Wheels" }}
      </button>
    </div>
  </div>

  <div class="autosync-wheel-finder__results autosync-wheel-finder--hidden" data-autosync-wheel-results>
    <!-- Results populated by JS -->
  </div>
  {% unless shop.metafields['$app:autosync']['hide_watermark'].value == true %}
    <div class="autosync-widget-footer">
      <img src="{{ 'autosync-logo.svg' | asset_url }}" alt="AutoSync" width="14" height="14">
      <span>Powered by <strong>AutoSync</strong></span>
    </div>
  {% endunless %}
</div>

{{ 'autosync-widgets.css' | asset_url | stylesheet_tag }}
<script src="{{ 'autosync-widgets.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
"name": "Wheel Finder",
"target": "section",
"settings": [
{
"type": "header",
"content": "Content"
},
{
"type": "text",
"id": "heading",
"label": "Heading",
"default": "Find Wheels"
},
{
"type": "text",
"id": "subheading",
"label": "Subheading",
"default": "Search by bolt pattern, offset, and bore size"
},
{
"type": "text",
"id": "button_text",
"label": "Button Text",
"default": "Search Wheels"
},
{
"type": "select",
"id": "heading_alignment",
"label": "Heading Alignment",
"default": "center",
"options": [
{ "value": "left", "label": "Left" },
{ "value": "center", "label": "Center" }
]
},
{
"type": "header",
"content": "Colors"
},
{
"type": "color",
"id": "primary_color",
"label": "Primary Color",
"default": "#005bd2"
},
{
"type": "color",
"id": "background_color",
"label": "Background Color",
"default": "#ffffff"
},
{
"type": "color",
"id": "text_color",
"label": "Text Color",
"default": "#1a1a2e"
},
{
"type": "color",
"id": "muted_color",
"label": "Muted Text Color",
"default": "#6b7280"
},
{
"type": "color",
"id": "border_color",
"label": "Border Color",
"default": "#e5e7eb"
},
{
"type": "color",
"id": "card_bg",
"label": "Card Background",
"default": "#f9fafb"
},
{
"type": "range",
"id": "border_radius",
"label": "Border Radius",
"min": 0,
"max": 24,
"step": 2,
"default": 10,
"unit": "px"
},
{
"type": "header",
"content": "Layout"
},
{
"type": "select",
"id": "container_width",
"label": "Container Width",
"default": "1200",
"options": [
{ "value": "full", "label": "Full Width" },
{ "value": "1200", "label": "1200px" },
{ "value": "800", "label": "800px (Narrow)" }
]
},
{
"type": "range",
"id": "padding_top",
"label": "Top Padding",
"min": 0,
"max": 100,
"step": 4,
"default": 40,
"unit": "px"
},
{
"type": "range",
"id": "padding_bottom",
"label": "Bottom Padding",
"min": 0,
"max": 100,
"step": 4,
"default": 40,
"unit": "px"
}
]
}
{% endschema %}
