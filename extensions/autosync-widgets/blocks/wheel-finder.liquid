{% comment %}
  AutoSync Wheel Finder
  Search wheels by PCD, offset, and diameter
{% endcomment %}
{% liquid
  assign allowed_widgets_raw = shop.metafields['$app:autosync']['allowed_widgets'].value
  assign wheel_allowed = false
  if allowed_widgets_raw != blank
    if allowed_widgets_raw.wheel == true
      assign wheel_allowed = true
    endif
  endif
%}
{% if wheel_allowed == false %}
<!-- widget not available on current plan -->
{% else %}
<div
  class="autosync-wheel-finder"
  data-autosync-wheel-finder
  data-proxy-url="{{ shop.url }}/apps/autosync"
  data-currency-symbol="{{ cart.currency.symbol }}"
  data-currency-code="{{ cart.currency.iso_code }}"
  data-hide-watermark="{{ shop.metafields['$app:autosync']['hide_watermark'].value | default: false }}"
  id="autosync-wheel-finder-{{ block.id }}"
  style="
    --awf-primary: {{ block.settings.primary_color | default: '#005bd2' }};
    --awf-bg: {{ block.settings.background_color | default: '#ffffff' }};
    --awf-text: {{ block.settings.text_color | default: '#1a1a2e' }};
    --awf-muted: {{ block.settings.muted_color | default: '#6b7280' }};
    --awf-border: {{ block.settings.border_color | default: '#e5e7eb' }};
    --awf-card-bg: {{ block.settings.card_bg | default: '#f9fafb' }};
    --awf-radius: {{ block.settings.border_radius | default: 8 }}px;
    --as-primary: {{ block.settings.primary_color | default: '#005bd2' }};
    --as-bg: {{ block.settings.background_color | default: '#ffffff' }};
    --as-text: {{ block.settings.text_color | default: '#1a1a2e' }};
    --as-muted: {{ block.settings.muted_color | default: '#6b7280' }};
    --as-border: {{ block.settings.border_color | default: '#e5e7eb' }};
    --as-card-bg: {{ block.settings.card_bg | default: '#f9fafb' }};
    --as-radius: {{ block.settings.border_radius | default: 8 }}px;
    --as-btn-bg: {{ block.settings.button_color | default: block.settings.primary_color | default: '#005bd2' }};
    --as-btn-text: {{ block.settings.button_text_color | default: '#ffffff' }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.container_padding | default: 24 }}px;
    padding-right: {{ block.settings.container_padding | default: 24 }}px;
    max-width: {% if block.settings.container_width == 'full' %}100%{% else %}{{ block.settings.container_width | default: '1200' }}px{% endif %};
    margin: 0 auto;
  "
>
  {% if block.settings.heading != blank %}
    <h2 class="autosync-wheel-finder__heading" style="text-align: {{ block.settings.heading_alignment | default: 'center' }};">{{ block.settings.heading }}</h2>
  {% endif %}
  {% if block.settings.subheading != blank %}
    <p class="autosync-wheel-finder__subheading" style="text-align: {{ block.settings.heading_alignment | default: 'center' }};">{{ block.settings.subheading }}</p>
  {% endif %}

  <div class="autosync-wheel-finder__fields">
    <div class="autosync-wheel-finder__field">
      <label for="autosync-pcd-{{ block.id }}">PCD (Bolt Pattern)</label>
      <select id="autosync-pcd-{{ block.id }}" data-autosync-wheel-level="pcd">
        <option value="">Loading...</option>
      </select>
    </div>

    <div class="autosync-wheel-finder__field">
      <label for="autosync-diameter-{{ block.id }}">Diameter</label>
      <select id="autosync-diameter-{{ block.id }}" data-autosync-wheel-level="diameter" disabled>
        <option value="">Select PCD first</option>
      </select>
    </div>

    <div class="autosync-wheel-finder__field">
      <label for="autosync-width-{{ block.id }}">Width</label>
      <select id="autosync-width-{{ block.id }}" data-autosync-wheel-level="width" disabled>
        <option value="">Select Diameter first</option>
      </select>
    </div>

    <div class="autosync-wheel-finder__field">
      <label for="autosync-offset-{{ block.id }}">Offset (ET)</label>
      <select id="autosync-offset-{{ block.id }}" data-autosync-wheel-level="offset" disabled>
        <option value="">Select Width first</option>
      </select>
    </div>

    <div class="autosync-wheel-finder__field autosync-wheel-finder__field--button">
      <button type="button" data-autosync-wheel-search disabled>
        {{ block.settings.button_text | default: "Search Wheels" }}
      </button>
    </div>
  </div>

  <div class="autosync-wheel-finder__results autosync-wheel-finder--hidden" data-autosync-wheel-results>
    <!-- Results populated by JS -->
  </div>
  {% unless shop.metafields['$app:autosync']['hide_watermark'].value == true %}
    <div class="autosync-widget-footer">
      <img src="{{ 'autosync-logo.svg' | asset_url }}" alt="AutoSync" width="14" height="14">
      <span>Powered by <strong>AutoSync</strong></span>
    </div>
  {% endunless %}
</div>

{{ 'autosync-widgets.css' | asset_url | stylesheet_tag }}
<script src="{{ 'autosync-widgets.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
"name": "Wheel Finder",
"target": "section",
"settings": [
{
"type": "header",
"content": "Content"
},
{
"type": "text",
"id": "heading",
"label": "Heading",
"default": "Find Wheels"
},
{
"type": "text",
"id": "subheading",
"label": "Subheading",
"default": "Search by bolt pattern, offset, and bore size"
},
{
"type": "text",
"id": "button_text",
"label": "Button Text",
"default": "Search Wheels"
},
{
"type": "select",
"id": "heading_alignment",
"label": "Heading Alignment",
"default": "center",
"options": [
{ "value": "left", "label": "Left" },
{ "value": "center", "label": "Center" }
]
},
{
"type": "header",
"content": "Colors"
},
{
"type": "color",
"id": "primary_color",
"label": "Primary Color",
"default": "#005bd2"
},
{
"type": "color",
"id": "background_color",
"label": "Background Color",
"default": "#ffffff"
},
{
"type": "color",
"id": "text_color",
"label": "Text Color",
"default": "#1a1a2e"
},
{
"type": "color",
"id": "muted_color",
"label": "Muted Text Color",
"default": "#6b7280"
},
{
"type": "color",
"id": "border_color",
"label": "Border Color",
"default": "#e5e7eb"
},
{
"type": "color",
"id": "card_bg",
"label": "Card Background",
"default": "#f9fafb"
},
{
"type": "color",
"id": "button_color",
"label": "Button Color",
"default": "#005bd2"
},
{
"type": "color",
"id": "button_text_color",
"label": "Button Text Color",
"default": "#ffffff"
},
{
"type": "header",
"content": "Layout"
},
{
"type": "select",
"id": "container_width",
"label": "Container Width",
"default": "1200",
"options": [
{ "value": "full", "label": "Full Width" },
{ "value": "1400", "label": "Extra Wide (1400px)" },
{ "value": "1200", "label": "Standard (1200px)" },
{ "value": "1000", "label": "Medium (1000px)" },
{ "value": "800", "label": "Narrow (800px)" }
]
},
{
"type": "range",
"id": "container_padding",
"label": "Container Padding",
"min": 0,
"max": 60,
"step": 4,
"default": 24,
"unit": "px"
},
{
"type": "range",
"id": "border_radius",
"label": "Border Radius",
"min": 0,
"max": 24,
"step": 2,
"default": 8,
"unit": "px"
},
{
"type": "range",
"id": "padding_top",
"label": "Top Padding",
"min": 0,
"max": 100,
"step": 4,
"default": 40,
"unit": "px"
},
{
"type": "range",
"id": "padding_bottom",
"label": "Bottom Padding",
"min": 0,
"max": 100,
"step": 4,
"default": 40,
"unit": "px"
}
]
}
{% endschema %}
