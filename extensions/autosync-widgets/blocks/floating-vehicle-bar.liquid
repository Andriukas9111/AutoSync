{% liquid
  assign logo_url = 'autosync-logo.svg' | asset_url
  assign pos = block.settings.position | default: 'top'
%}
<div class="avb avb--{{ pos }}" data-autosync-vehicle-bar id="avb-{{ block.id }}" style="--avb-bg:{{ block.settings.background_color | default: '#1a1a2e' }};--avb-text:{{ block.settings.text_color | default: '#ffffff' }};--avb-accent:{{ block.settings.accent_color | default: '#005bd2' }};--avb-muted:{{ block.settings.muted_color | default: 'rgba(255,255,255,0.6)' }};">
  <div class="avb__inner">
    <div class="avb__left">
      <img src="{{ logo_url }}" alt="AutoSync" width="16" height="16" class="avb__logo"/>
      <span class="avb__heading">YOUR CURRENT VEHICLE</span>
    </div>
    <div class="avb__details" data-avb-details></div>
    <div class="avb__right">
      <button type="button" class="avb__btn" data-avb-change>Change</button>
      <button type="button" class="avb__btn avb__btn--close" data-avb-toggle title="Hide vehicle bar">&times;</button>
    </div>
  </div>
  <button type="button" class="avb__tab avb__tab--{{ pos }}" data-avb-tab>
    <img src="{{ logo_url }}" alt="" width="14" height="14"/>
    <span data-avb-tab-text>Show Vehicle</span>
  </button>
</div>

{{ 'autosync-widgets.css' | asset_url | stylesheet_tag }}

<script>
(function(){
var root=document.getElementById('avb-{{ block.id }}');if(!root)return;
var det=root.querySelector('[data-avb-details]'),chB=root.querySelector('[data-avb-change]'),tgB=root.querySelector('[data-avb-toggle]'),tab=root.querySelector('[data-avb-tab]'),tT=root.querySelector('[data-avb-tab-text]'),HK='autosync_bar_hidden';
function gV(){try{var g=localStorage.getItem('autosync_garage');if(g){var a=JSON.parse(g);if(Array.isArray(a)&&a.length>0)return a[0];}var v=localStorage.getItem('autosync_vehicle');if(v)return JSON.parse(v);}catch(e){}return null;}
function fR(r){if(!r)return'';r=r.replace(/\s/g,'').toUpperCase();return r.length===7?r.substring(0,4)+' '+r.substring(4):r;}
function up(){var v=gV();if(!v||!v.makeName){root.classList.remove('avb--visible');tab.classList.remove('avb__tab--show');return;}
var h=false;try{h=localStorage.getItem(HK)==='1';}catch(e){}
if(h){root.classList.remove('avb--visible');tab.classList.add('avb__tab--show');if(tT)tT.textContent=v.makeName+' '+v.modelName;return;}
root.classList.add('avb--visible');tab.classList.remove('avb__tab--show');
while(det.firstChild)det.removeChild(det.firstChild);
if(v.source==='plate-lookup'&&v.reg){var rb=document.createElement('div');rb.className='avb__reg';var fl=document.createElement('span');fl.className='avb__reg-flag';fl.textContent='GB';rb.appendChild(fl);var rt=document.createElement('span');rt.className='avb__reg-text';rt.textContent=fR(v.reg);rb.appendChild(rt);det.appendChild(rb);}
var fs=[];if(v.makeName)fs.push(['Manufacturer',v.makeName]);if(v.modelName)fs.push(['Model',v.modelName]);if(v.year)fs.push(['Year',v.year]);if(v.engineCapacity)fs.push(['Engine',v.engineCapacity]);if(v.fuelType)fs.push(['Fuel',v.fuelType]);if(v.colour)fs.push(['Colour',v.colour]);
for(var i=0;i<fs.length;i++){var d=document.createElement('div');d.className='avb__detail';var lb=document.createElement('span');lb.className='avb__detail-label';lb.textContent=fs[i][0];d.appendChild(lb);var vl=document.createElement('span');vl.className='avb__detail-value';vl.textContent=fs[i][1];d.appendChild(vl);det.appendChild(d);}}
if(chB)chB.addEventListener('click',function(){var y=document.querySelector('[data-autosync-ymme]')||document.querySelector('[data-apl-root]');if(y)y.scrollIntoView({behavior:'smooth',block:'center'});});
if(tgB)tgB.addEventListener('click',function(){try{localStorage.setItem(HK,'1');}catch(e){}up();});
if(tab)tab.addEventListener('click',function(){try{localStorage.removeItem(HK);}catch(e){}up();});
up();window.addEventListener('autosync:vehicle-changed',up);window.addEventListener('autosync:garage-changed',up);
})();
</script>

{% schema %}
{
  "name": "Vehicle Bar (Persistent)",
  "target": "section",
  "settings": [
    { "type": "select", "id": "position", "label": "Position", "options": [{ "value": "top", "label": "Top" }, { "value": "bottom", "label": "Bottom" }], "default": "top" },
    { "type": "color", "id": "background_color", "label": "Background Color", "default": "#1a1a2e" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Accent Color", "default": "#005bd2" },
    { "type": "color", "id": "muted_color", "label": "Label Color", "default": "rgba(255,255,255,0.6)" }
  ]
}
{% endschema %}
