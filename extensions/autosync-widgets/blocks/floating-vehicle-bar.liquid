{% comment %}
  AutoSync Floating Vehicle Bar
  Persistent bar showing the customer's selected vehicle
{% endcomment %}

{% liquid
  assign logo_url = 'autosync-logo.svg' | asset_url
%}

<div
  class="autosync-vehicle-bar autosync-vehicle-bar--{{ block.settings.position }} autosync-vehicle-bar--hidden"
  data-autosync-vehicle-bar
  id="autosync-vehicle-bar-{{ block.id }}"
  style="
    --autosync-bar-bg: {{ block.settings.background_color }};
    --autosync-bar-text: {{ block.settings.text_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  "
>
  <div class="autosync-vehicle-bar__inner">
    <img class="autosync-vehicle-bar__icon" src="{{ logo_url }}" alt="AutoSync" width="18" height="18" style="vertical-align: middle;" />
    <span class="autosync-vehicle-bar__label">Your Vehicle:</span>
    <span class="autosync-vehicle-bar__vehicle" data-autosync-bar-vehicle></span>

    <div class="autosync-vehicle-bar__actions">
      <button type="button" class="autosync-vehicle-bar__btn" data-autosync-bar-change>
        Change Vehicle
      </button>
      <button type="button" class="autosync-vehicle-bar__btn autosync-vehicle-bar__btn--clear" data-autosync-bar-clear>
        Clear
      </button>
    </div>
  </div>
</div>

{{ 'autosync-widgets.css' | asset_url | stylesheet_tag }}
<script src="{{ 'autosync-widgets.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Floating Vehicle Bar",
  "target": "section",
  "settings": [
    {
      "type": "select",
      "id": "position",
      "label": "Position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "top"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ]
}
{% endschema %}
