{% comment %}
  AutoSync Fitment Badge
  Shows "Fits your vehicle" or "May not fit" based on stored vehicle in localStorage
{% endcomment %}

<div
  class="autosync-fitment-badge"
  data-autosync-fitment-badge
  data-proxy-url="{{ shop.url }}/apps/autosync"
  data-product-id="{{ product.id }}"
  data-product-tags="{{ product.tags | join: ',' }}"
  data-product-metafield-make="{{ product.metafields.autosync_fitment.make_names.value | json }}"
  data-product-metafield-model="{{ product.metafields.autosync_fitment.model_names.value | json }}"
  id="autosync-fitment-badge-{{ block.id }}"
  style="
    --autosync-badge-success: {{ block.settings.success_color }};
    --autosync-badge-warning: {{ block.settings.warning_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  "
>
  <div class="autosync-fitment-badge__content autosync-fitment-badge--hidden" data-autosync-badge-fits>
    <span class="autosync-fitment-badge__icon autosync-fitment-badge__icon--success">&#10003;</span>
    <span class="autosync-fitment-badge__text">
      Fits your vehicle
      {% if block.settings.show_vehicle_name %}
        <span data-autosync-badge-vehicle-name class="autosync-fitment-badge__vehicle"></span>
      {% endif %}
    </span>
  </div>

  <div class="autosync-fitment-badge__content autosync-fitment-badge--hidden" data-autosync-badge-nofit>
    <span class="autosync-fitment-badge__icon autosync-fitment-badge__icon--warning">&#9888;</span>
    <span class="autosync-fitment-badge__text">May not fit your vehicle</span>
  </div>

  <div class="autosync-fitment-badge__content autosync-fitment-badge--hidden" data-autosync-badge-novehicle>
    <a href="#" data-autosync-badge-select-vehicle class="autosync-fitment-badge__link">
      Select your vehicle to check fitment
    </a>
  </div>
</div>

{{ 'autosync-widgets.css' | asset_url | stylesheet_tag }}
<script src="{{ 'autosync-widgets.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Fitment Badge",
  "target": "section",
  "settings": [
    {
      "type": "color",
      "id": "success_color",
      "label": "Success Color",
      "default": "#1a7f37"
    },
    {
      "type": "color",
      "id": "warning_color",
      "label": "Warning Color",
      "default": "#bf5700"
    },
    {
      "type": "checkbox",
      "id": "show_vehicle_name",
      "label": "Show Vehicle Name",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    }
  ]
}
{% endschema %}
