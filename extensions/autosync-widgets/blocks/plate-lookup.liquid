{% comment %}
  AutoSync Plate Lookup — Premium Edition
  Enterprise-only feature — DVLA VES + MOT History via App Proxy
  Features: UK plate styling, vehicle card, MOT timeline, defect list, compatible products
{% endcomment %}

{% liquid
  assign proxy_url = shop.url | append: '/apps/autosync'
%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

<div
  class="apl-root"
  data-apl-root
  data-proxy-url="{{ proxy_url }}"
  data-show-mot="{{ block.settings.show_mot_history | default: true }}"
  data-show-products="{{ block.settings.show_products | default: true }}"
  data-show-tax="{{ block.settings.show_tax_status | default: true }}"
  id="apl-{{ block.id }}"
  style="
    --apl-primary: {{ block.settings.primary_color | default: '#2563eb' }};
    --apl-bg: {{ block.settings.background_color | default: '#ffffff' }};
    --apl-text: {{ block.settings.text_color | default: '#1a1a2e' }};
    --apl-muted: {{ block.settings.muted_color | default: '#6b7280' }};
    --apl-border: {{ block.settings.border_color | default: '#e5e7eb' }};
    --apl-card-bg: {{ block.settings.card_bg | default: '#f9fafb' }};
    --apl-radius: {{ block.settings.border_radius | default: 12 }}px;
    --apl-success: #10b981;
    --apl-danger: #ef4444;
    --apl-warning: #f59e0b;
    padding-top: {{ block.settings.padding_top | default: 40 }}px;
    padding-bottom: {{ block.settings.padding_bottom | default: 40 }}px;
    max-width: {% if block.settings.container_width == 'full' %}100%{% else %}{{ block.settings.container_width | default: '1200' }}px{% endif %};
    padding-left: {{ block.settings.container_padding | default: 24 }}px;
    padding-right: {{ block.settings.container_padding | default: 24 }}px;
  "
>
  {% if block.settings.heading != blank %}
    <div class="apl-heading-wrap" style="text-align: {{ block.settings.heading_alignment | default: 'center' }};">
      <div class="apl-heading-accent" {% if block.settings.heading_alignment == 'left' %}style="margin-left: 0;"{% endif %}></div>
      <h2 class="apl-heading">{{ block.settings.heading }}</h2>
    </div>
  {% endif %}

  {% if block.settings.subheading != blank %}
    <p class="apl-subheading" style="text-align: {{ block.settings.heading_alignment | default: 'center' }};">{{ block.settings.subheading }}</p>
  {% endif %}

  <!-- UK Number Plate Input -->
  <div class="apl-plate-form">
    <div class="apl-plate-input-wrap">
      <div class="apl-plate-badge">
        <div class="apl-plate-badge__flag">
          <div class="apl-plate-badge__stars">
            <span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span>
          </div>
          <span class="apl-plate-badge__text">GB</span>
        </div>
      </div>
      <input
        type="text"
        class="apl-plate-input"
        data-apl-input
        placeholder="{{ block.settings.placeholder_text | default: 'Enter reg number' }}"
        maxlength="8"
        autocomplete="off"
        spellcheck="false"
      />
    </div>
    <button type="button" class="apl-submit-btn" data-apl-submit>
      <svg class="apl-submit-btn__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <span>{{ block.settings.button_text | default: "Look Up" }}</span>
    </button>
  </div>

  <!-- Loading -->
  <div class="apl-loading" data-apl-loading style="display:none;">
    <div class="apl-spinner"></div>
    <p class="apl-loading__text">Looking up vehicle...</p>
  </div>

  <!-- Error -->
  <div class="apl-error" data-apl-error style="display:none;">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
    <p class="apl-error__msg" data-apl-error-msg>Something went wrong.</p>
    <button type="button" class="apl-error__retry" data-apl-retry>Try Again</button>
  </div>

  <!-- Results (populated by JS) -->
  <div class="apl-results" data-apl-results style="display:none;"></div>
</div>

<style>
  .apl-root { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; color: var(--apl-text); background: var(--apl-bg); margin: 0 auto; -webkit-font-smoothing: antialiased; }
  .apl-root *, .apl-root *::before, .apl-root *::after { box-sizing: border-box; }
  .apl-heading-wrap { text-align: center; margin-bottom: 8px; }
  .apl-heading-accent { width: 48px; height: 4px; border-radius: 2px; background: linear-gradient(135deg, var(--apl-primary), color-mix(in srgb, var(--apl-primary) 60%, #a855f7)); margin: 0 auto 14px; }
  .apl-heading { font-size: 28px; font-weight: 800; margin: 0; letter-spacing: -0.03em; line-height: 1.2; background: linear-gradient(135deg, var(--apl-text) 0%, color-mix(in srgb, var(--apl-text) 70%, var(--apl-primary)) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .apl-subheading { font-size: 15px; color: var(--apl-muted); margin: 0 0 28px; font-weight: 400; line-height: 1.5; }
  .apl-plate-form { display: flex; gap: 12px; max-width: 540px; margin: 0 auto 32px; align-items: stretch; }
  .apl-plate-input-wrap { flex: 1; display: flex; position: relative; border: 2px solid #ffc107; border-radius: var(--apl-radius); background: #ffc107; overflow: hidden; transition: box-shadow 0.25s ease; }
  .apl-plate-input-wrap:focus-within { box-shadow: 0 0 0 4px rgba(255, 193, 7, 0.25); }
  .apl-plate-badge { display: flex; align-items: center; justify-content: center; background: #003da5; padding: 0 10px; flex-shrink: 0; }
  .apl-plate-badge__flag { display: flex; flex-direction: column; align-items: center; gap: 2px; }
  .apl-plate-badge__stars { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; }
  .apl-plate-badge__stars span { width: 3px; height: 3px; border-radius: 50%; background: #ffc107; }
  .apl-plate-badge__text { font-size: 10px; font-weight: 800; color: #ffffff; letter-spacing: 0.05em; }
  .apl-plate-input { flex: 1; border: none; outline: none; background: #ffc107; font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; font-size: 26px; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; padding: 14px 16px; color: #1a1a1a; text-align: center; min-width: 0; }
  .apl-plate-input::placeholder { color: rgba(0,0,0,0.3); font-size: 15px; font-weight: 500; letter-spacing: 0; text-transform: none; }
  .apl-submit-btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border: none; border-radius: var(--apl-radius); background: var(--apl-primary); color: #fff; cursor: pointer; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700; transition: background 0.2s, transform 0.15s, box-shadow 0.2s; white-space: nowrap; }
  .apl-submit-btn:hover { background: color-mix(in srgb, var(--apl-primary) 85%, #000); transform: translateY(-1px); box-shadow: 0 4px 12px color-mix(in srgb, var(--apl-primary) 30%, transparent); }
  .apl-submit-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; box-shadow: none; }
  .apl-loading { display: flex; flex-direction: column; align-items: center; padding: 48px 20px; gap: 14px; }
  .apl-spinner { width: 32px; height: 32px; border: 3px solid var(--apl-border); border-top-color: var(--apl-primary); border-radius: 50%; animation: apl-spin 0.7s linear infinite; }
  @keyframes apl-spin { to { transform: rotate(360deg); } }
  .apl-loading__text { font-size: 14px; color: var(--apl-muted); font-weight: 500; margin: 0; }
  .apl-error { text-align: center; padding: 48px 20px; color: var(--apl-muted); }
  .apl-error svg { margin: 0 auto 12px; display: block; }
  .apl-error__msg { margin: 0 0 16px; font-size: 14px; font-weight: 500; }
  .apl-error__retry { padding: 10px 24px; border: 1px solid var(--apl-border); border-radius: var(--apl-radius); background: var(--apl-bg); color: var(--apl-text); cursor: pointer; font-size: 13px; font-weight: 600; font-family: inherit; transition: border-color 0.2s, background 0.2s; }
  .apl-error__retry:hover { border-color: var(--apl-primary); background: var(--apl-card-bg); }
  .apl-vehicle-card { background: var(--apl-bg); border: 1px solid var(--apl-border); border-radius: calc(var(--apl-radius) + 4px); overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.04); max-width: 700px; margin: 0 auto; animation: apl-slideUp 0.35s ease both; }
  @keyframes apl-slideUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  .apl-vehicle-card__header { background: linear-gradient(135deg, #0a0f1e, #1a2744); color: #fff; padding: 28px 28px 24px; position: relative; }
  .apl-vehicle-card__header::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 80% 20%, rgba(37,99,235,0.12) 0%, transparent 60%); pointer-events: none; }
  .apl-vehicle-card__reg { display: inline-flex; align-items: center; background: #ffc107; color: #1a1a1a; padding: 6px 16px; border-radius: 6px; font-size: 20px; font-weight: 800; letter-spacing: 0.05em; margin-bottom: 14px; position: relative; z-index: 1; }
  .apl-vehicle-card__reg-flag { background: #003da5; color: #fff; font-size: 9px; font-weight: 800; padding: 4px 6px; border-radius: 3px 0 0 3px; margin-left: -16px; margin-right: 10px; letter-spacing: 0.05em; }
  .apl-vehicle-card__title { font-size: 28px; font-weight: 900; margin: 0 0 4px; letter-spacing: -0.02em; line-height: 1.2; position: relative; z-index: 1; }
  .apl-vehicle-card__subtitle { font-size: 14px; font-weight: 400; color: rgba(255,255,255,0.5); margin: 0; position: relative; z-index: 1; }
  .apl-details { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
  .apl-detail { padding: 16px 20px; border-bottom: 1px solid var(--apl-border); border-right: 1px solid var(--apl-border); }
  .apl-detail:nth-child(2n) { border-right: none; }
  .apl-detail:nth-last-child(-n+2) { border-bottom: none; }
  .apl-detail__label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--apl-muted); font-weight: 600; margin: 0 0 4px; }
  .apl-detail__value { font-size: 15px; font-weight: 700; color: var(--apl-text); margin: 0; }
  .apl-status { display: inline-flex; align-items: center; gap: 5px; padding: 3px 10px; border-radius: 100px; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; }
  .apl-status--pass { background: color-mix(in srgb, var(--apl-success) 12%, var(--apl-bg)); color: var(--apl-success); }
  .apl-status--fail { background: color-mix(in srgb, var(--apl-danger) 12%, var(--apl-bg)); color: var(--apl-danger); }
  .apl-status--warn { background: color-mix(in srgb, var(--apl-warning) 12%, var(--apl-bg)); color: var(--apl-warning); }
  .apl-status__dot { width: 7px; height: 7px; border-radius: 50%; }
  .apl-status--pass .apl-status__dot { background: var(--apl-success); }
  .apl-status--fail .apl-status__dot { background: var(--apl-danger); }
  .apl-status--warn .apl-status__dot { background: var(--apl-warning); }
  .apl-find-parts { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 16px; background: var(--apl-card-bg); border-top: 1px solid var(--apl-border); font-size: 14px; font-weight: 700; color: var(--apl-primary); cursor: pointer; transition: background 0.2s; border: none; width: 100%; font-family: inherit; }
  .apl-find-parts:hover { background: color-mix(in srgb, var(--apl-primary) 8%, var(--apl-bg)); }
  .apl-mot-section { max-width: 700px; margin: 28px auto 0; animation: apl-slideUp 0.4s ease 0.1s both; }
  .apl-mot-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .apl-mot-title { font-size: 18px; font-weight: 800; margin: 0; letter-spacing: -0.02em; display: flex; align-items: center; gap: 8px; }
  .apl-mot-title svg { color: var(--apl-primary); }
  .apl-mot-count { font-size: 12px; font-weight: 600; color: var(--apl-muted); padding: 4px 12px; border-radius: 20px; background: var(--apl-card-bg); border: 1px solid var(--apl-border); }
  .apl-mot-timeline { list-style: none; padding: 0; margin: 0; }
  .apl-mot-item { position: relative; padding: 0 0 0 32px; margin-bottom: 0; }
  .apl-mot-item::before { content: ''; position: absolute; left: 10px; top: 28px; bottom: -1px; width: 2px; background: var(--apl-border); }
  .apl-mot-item:last-child::before { display: none; }
  .apl-mot-dot { position: absolute; left: 3px; top: 18px; width: 16px; height: 16px; border-radius: 50%; border: 3px solid var(--apl-bg); z-index: 1; }
  .apl-mot-dot--pass { background: var(--apl-success); }
  .apl-mot-dot--fail { background: var(--apl-danger); }
  .apl-mot-card { background: var(--apl-bg); border: 1px solid var(--apl-border); border-radius: var(--apl-radius); padding: 18px 20px; margin-bottom: 14px; transition: border-color 0.2s; }
  .apl-mot-card:hover { border-color: color-mix(in srgb, var(--apl-primary) 30%, var(--apl-border)); }
  .apl-mot-card__top { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 8px; }
  .apl-mot-card__date { font-size: 14px; font-weight: 700; color: var(--apl-text); }
  .apl-mot-card__mileage { font-size: 13px; font-weight: 500; color: var(--apl-muted); display: flex; align-items: center; gap: 4px; }
  .apl-mot-card__expiry { font-size: 12px; color: var(--apl-muted); font-weight: 500; margin: 0; }
  .apl-defects { margin-top: 12px; }
  .apl-defect { display: flex; align-items: flex-start; gap: 8px; padding: 8px 12px; border-radius: 8px; margin-bottom: 6px; font-size: 13px; line-height: 1.45; font-weight: 500; }
  .apl-defect--advisory { background: color-mix(in srgb, var(--apl-warning) 8%, var(--apl-bg)); color: var(--apl-text); }
  .apl-defect--major, .apl-defect--dangerous { background: color-mix(in srgb, var(--apl-danger) 8%, var(--apl-bg)); color: var(--apl-text); }
  .apl-defect--minor { background: color-mix(in srgb, var(--apl-muted) 8%, var(--apl-bg)); color: var(--apl-text); }
  .apl-defect__icon { flex-shrink: 0; margin-top: 2px; }
  .apl-defect__type { font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700; margin-top: 3px; display: block; }
  .apl-defect--advisory .apl-defect__type { color: var(--apl-warning); }
  .apl-defect--major .apl-defect__type, .apl-defect--dangerous .apl-defect__type { color: var(--apl-danger); }
  .apl-defect--minor .apl-defect__type { color: var(--apl-muted); }
  .apl-products-section { max-width: 700px; margin: 28px auto 0; animation: apl-slideUp 0.4s ease 0.15s both; }
  .apl-products-title { font-size: 18px; font-weight: 800; margin: 0 0 16px; letter-spacing: -0.02em; }
  .apl-products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 14px; }
  .apl-product { border: 1px solid var(--apl-border); border-radius: var(--apl-radius); overflow: hidden; text-decoration: none; color: inherit; display: block; transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s; }
  .apl-product:hover { border-color: var(--apl-primary); transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
  .apl-product__img { width: 100%; aspect-ratio: 1; object-fit: cover; display: block; background: var(--apl-card-bg); }
  .apl-product__body { padding: 10px 12px; }
  .apl-product__title { font-size: 12px; font-weight: 600; margin: 0 0 6px; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .apl-product__price { font-size: 14px; font-weight: 700; color: var(--apl-primary); margin: 0; }
  .apl-footer { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 24px 0 0; margin-top: 32px; max-width: 700px; margin-left: auto; margin-right: auto; border-top: 1px solid var(--apl-border); font-size: 12px; color: var(--apl-muted); opacity: 0.5; }
  .apl-footer svg { color: var(--apl-primary); }
  .apl-footer strong { font-weight: 700; color: var(--apl-primary); }
  @media (max-width: 600px) {
    .apl-heading { font-size: 22px; }
    .apl-plate-form { flex-direction: column; }
    .apl-plate-input { font-size: 22px; padding: 12px 14px; }
    .apl-submit-btn { justify-content: center; }
    .apl-details { grid-template-columns: 1fr; }
    .apl-detail { border-right: none !important; }
    .apl-detail:last-child { border-bottom: none; }
    .apl-vehicle-card__header { padding: 22px 20px 20px; }
    .apl-vehicle-card__title { font-size: 22px; }
    .apl-mot-card__top { flex-direction: column; align-items: flex-start; gap: 6px; }
    .apl-products-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  }
</style>

<script>
(function() {
  var root = document.getElementById('apl-{{ block.id }}');
  if (!root) return;

  var proxyUrl = root.dataset.proxyUrl;
  var loadingEl = root.querySelector('[data-apl-loading]');
  var errorEl = root.querySelector('[data-apl-error]');
  var resultsEl = root.querySelector('[data-apl-results]');
  var input = root.querySelector('[data-apl-input]');
  var submitBtn = root.querySelector('[data-apl-submit]');
  var retryBtn = root.querySelector('[data-apl-retry]');
  var originalBtnHTML = submitBtn ? submitBtn.textContent : '';
  var lastReg = '';

  if (!input || !submitBtn) return;

  input.addEventListener('input', function() { this.value = this.value.toUpperCase().replace(/[^A-Z0-9 ]/g, ''); });
  input.addEventListener('keydown', function(e) { if (e.key === 'Enter') submitBtn.click(); });
  if (retryBtn) retryBtn.addEventListener('click', function() { if (lastReg) doLookup(lastReg); });

  submitBtn.addEventListener('click', function() {
    var reg = input.value.trim().replace(/\s+/g, '');
    if (reg.length < 2) return;
    lastReg = reg;
    doLookup(reg);
  });

  function doLookup(reg) {
    submitBtn.disabled = true;
    submitBtn.textContent = 'Looking up...';
    errorEl.style.display = 'none';
    resultsEl.style.display = 'none';

    fetch(proxyUrl + '?path=plate-lookup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ registration: reg }),
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalBtnHTML;
        if (data.error) { showError(data.error); return; }
        if (data.vehicle) renderResults(data.vehicle, data.motHistory, data.compatibleProducts || [], reg);
      })
      .catch(function() {
        submitBtn.disabled = false;
        submitBtn.textContent = originalBtnHTML;
        showError('Failed to look up registration. Please try again.');
      });
  }

  function showError(msg) {
    var msgEl = errorEl.querySelector('[data-apl-error-msg]');
    if (msgEl) msgEl.textContent = msg;
    errorEl.style.display = 'block';
    resultsEl.style.display = 'none';
  }

  function el(tag, className, text) {
    var e = document.createElement(tag);
    if (className) e.className = className;
    if (text !== undefined && text !== null) e.textContent = String(text);
    return e;
  }

  /* Static SVG helper — only for known safe static icon strings */
  function svgIcon(markup) {
    var t = document.createElement('template');
    t.innerHTML = markup.trim();
    return t.content.firstChild;
  }

  var ICONS = {
    shield: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    search: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>',
    speed: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 0 0-6.88 17.23"/><path d="M12 2a10 10 0 0 1 6.88 17.23"/><line x1="12" y1="12" x2="12" y2="8"/></svg>',
    warn: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
    cross: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>',
    logo: '<svg width="20" height="20" viewBox="0 0 1200 1200" fill="none"><path fill="currentColor" d="M475.97,954.05l1.15-2.09c.26-.47.74-1.38.9-1.88,3.43-2.52,6.07-7.05,5.08-11.15.27-.44.68-1.39.85-1.87,3.7-2.85,6.29-7.47,6.15-12.07.3-.43.61-1.46.86-1.93l2.59-1.43c.75-.41.14-2.37-.47-2.71l.87-1.86,2.58-1.38c.75-.4.05-2.55-.44-2.87.23-.45.77-1.24,1.07-1.69,2-1.41,3.82-4.02,2.99-6.2l.79-1.86,2.64-1.4c.76-.41.1-2.42-.52-2.74l.87-1.86,2.5-1.27c.72-.37-.15-2.16-.37-2.88.23-.76.59-2.16.93-2.82,4.78-3.57,19-34.98,21.07-40.92.09-.25-.15-.79-.03-1.03,2.43-1.98,3.74-4.54,5.38-7.85l46.96-94.81c1.69-3.41,2.79-6.31,2.73-9.53,10.04-20.44,16.99-42.51,29.07-62.04,1.51-.81,2.45-3.2,2.96-4.78.18-.57.81-1.61,1.07-2.17,4.55-3.53,6.73-9.47,9.88-14.92,2.97-5.15,7.64-9.61,7.93-15.01.6-.88,1.65-2.22,2.17-3.08,2.18-1.23,4.45-3.6,3.83-5.93.56-.79,1.83-2.17,2.12-3.05,3.84-2.5,5.83-6.93,7.75-11.18,9.67-13.7,19.34-27.27,30.77-39.85l19.64-21.62c9.69-10.67,18.68-20.01,29.53-29.6l19.62-17.35,31.01-25.01c3.32-2.68,8.39-6.65,5.99-11.54l-25.43-51.94-75.53-151.3-67.09-134.73c-4.27-8.57-13.25-13.64-21.47-14.59-8.62-1-21.01,1.61-25.31,10.39l-47.54,96.96-13.24,28.33-80.24,165.62-48.41,99.53-250.39,517.49c-4.44,9.18-7.86,15.46-5.58,27.17,2.52,13,18.9,25.22,34.53,19.43l297.19-110.08c8.82-3.27,14-9.71,18.05-17.06Z"/><path fill="currentColor" d="M728.87,955.34c4.84,9.54,10.97,15.02,20.54,18.57l289.84,107.29c10.02,3.71,21.67-.68,27.65-6.95s11.2-18.55,6.35-28.37l-69.4-140.74-123.43-248.48-41.65-84.41-36.42-72.5c-.98-1.95-3.81-4.07-5.45-4.64s-5.59.13-7.09,1.43c-13.12,11.34-37.55,39.1-48.25,53.11-47.54,62.24-86.7,138.7-92.9,217.9-.78,9.91-3.53,20.04.33,29.51,6.35,15.6,14.58,29.51,22.26,44.66l57.62,113.62Z"/></svg>'
