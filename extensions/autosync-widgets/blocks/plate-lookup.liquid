{% comment %}
  AutoSync Plate Lookup — Premium Edition
  Enterprise-only feature — DVLA VES + MOT History via App Proxy
  Features: UK plate styling, vehicle card, MOT timeline, defect list, compatible products
{% endcomment %}

{% liquid
  assign proxy_url = shop.url | append: '/apps/autosync'
%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

<div
  class="apl-root"
  data-apl-root
  data-proxy-url="{{ proxy_url }}"
  data-show-mot="{{ block.settings.show_mot_history | default: true }}"
  data-show-products="{{ block.settings.show_products | default: true }}"
  data-show-tax="{{ block.settings.show_tax_status | default: true }}"
  id="apl-{{ block.id }}"
  style="
    --apl-primary: {{ block.settings.primary_color | default: '#2563eb' }};
    --apl-bg: {{ block.settings.background_color | default: '#ffffff' }};
    --apl-text: {{ block.settings.text_color | default: '#1a1a2e' }};
    --apl-muted: {{ block.settings.muted_color | default: '#6b7280' }};
    --apl-border: {{ block.settings.border_color | default: '#e5e7eb' }};
    --apl-card-bg: {{ block.settings.card_bg | default: '#f9fafb' }};
    --apl-radius: {{ block.settings.border_radius | default: 12 }}px;
    --apl-success: #10b981;
    --apl-danger: #ef4444;
    --apl-warning: #f59e0b;
    padding-top: {{ block.settings.padding_top | default: 40 }}px;
    padding-bottom: {{ block.settings.padding_bottom | default: 40 }}px;
    max-width: {% if block.settings.container_width == 'full' %}100%{% else %}{{ block.settings.container_width | default: '1200' }}px{% endif %};
    padding-left: {{ block.settings.container_padding | default: 24 }}px;
    padding-right: {{ block.settings.container_padding | default: 24 }}px;
  "
>
  {% if block.settings.heading != blank %}
    <div class="apl-heading-wrap" style="text-align: {{ block.settings.heading_alignment | default: 'center' }};">
      <div class="apl-heading-accent" {% if block.settings.heading_alignment == 'left' %}style="margin-left: 0;"{% endif %}></div>
      <h2 class="apl-heading">{{ block.settings.heading }}</h2>
    </div>
  {% endif %}

  {% if block.settings.subheading != blank %}
    <p class="apl-subheading" style="text-align: {{ block.settings.heading_alignment | default: 'center' }};">{{ block.settings.subheading }}</p>
  {% endif %}

  <!-- UK Number Plate Input -->
  <div class="apl-plate-form">
    <div class="apl-plate-input-wrap">
      <div class="apl-plate-badge">
        <div class="apl-plate-badge__flag">
          <div class="apl-plate-badge__stars">
            <span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span>
          </div>
          <span class="apl-plate-badge__text">GB</span>
        </div>
      </div>
      <input
        type="text"
        class="apl-plate-input"
        data-apl-input
        placeholder="{{ block.settings.placeholder_text | default: 'Enter reg number' }}"
        maxlength="8"
        autocomplete="off"
        spellcheck="false"
      />
    </div>
    <button type="button" class="apl-submit-btn" data-apl-submit>
      <svg class="apl-submit-btn__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <span>{{ block.settings.button_text | default: "Look Up" }}</span>
    </button>
  </div>

  <!-- Loading -->
  <div class="apl-loading" data-apl-loading style="display:none;">
    <div class="apl-spinner"></div>
    <p class="apl-loading__text">Looking up vehicle...</p>
  </div>

  <!-- Error -->
  <div class="apl-error" data-apl-error style="display:none;">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
    <p class="apl-error__msg" data-apl-error-msg>Something went wrong.</p>
    <button type="button" class="apl-error__retry" data-apl-retry>Try Again</button>
  </div>

  <!-- Results (populated by JS) -->
  <div class="apl-results" data-apl-results style="display:none;"></div>
</div>

{{ 'autosync-plate-lookup.css' | asset_url | stylesheet_tag }}

<script>
(function() {
  var root = document.getElementById('apl-{{ block.id }}');
  if (!root) return;

  var proxyUrl = root.dataset.proxyUrl;
  var loadingEl = root.querySelector('[data-apl-loading]');
  var errorEl = root.querySelector('[data-apl-error]');
  var resultsEl = root.querySelector('[data-apl-results]');
  var input = root.querySelector('[data-apl-input]');
  var submitBtn = root.querySelector('[data-apl-submit]');
  var retryBtn = root.querySelector('[data-apl-retry]');
  var originalBtnHTML = submitBtn ? submitBtn.textContent : '';
  var lastReg = '';

  if (!input || !submitBtn) return;

  input.addEventListener('input', function() { this.value = this.value.toUpperCase().replace(/[^A-Z0-9 ]/g, ''); });
  input.addEventListener('keydown', function(e) { if (e.key === 'Enter') submitBtn.click(); });
  if (retryBtn) retryBtn.addEventListener('click', function() { if (lastReg) doLookup(lastReg); });

  submitBtn.addEventListener('click', function() {
    var reg = input.value.trim().replace(/\s+/g, '');
    if (reg.length < 2) return;
    lastReg = reg;
    doLookup(reg);
  });

  function doLookup(reg) {
    submitBtn.disabled = true;
    submitBtn.textContent = 'Looking up...';
    errorEl.style.display = 'none';
    resultsEl.style.display = 'none';

    fetch(proxyUrl + '?path=plate-lookup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ registration: reg }),
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalBtnHTML;
        if (data.error) { showError(data.error); return; }
        if (data.vehicle) renderResults(data.vehicle, data.motHistory, data.compatibleProducts || [], reg);
      })
      .catch(function() {
        submitBtn.disabled = false;
        submitBtn.textContent = originalBtnHTML;
        showError('Failed to look up registration. Please try again.');
      });
  }

  function showError(msg) {
    var msgEl = errorEl.querySelector('[data-apl-error-msg]');
    if (msgEl) msgEl.textContent = msg;
    errorEl.style.display = 'block';
    resultsEl.style.display = 'none';
  }

  function el(tag, className, text) {
    var e = document.createElement(tag);
    if (className) e.className = className;
    if (text !== undefined && text !== null) e.textContent = String(text);
    return e;
  }

  
  function svgIcon(markup) {
    var t = document.createElement('template');
    t.innerHTML = markup.trim();
    return t.content.firstChild;
  }

  var ICONS = {
    shield: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    search: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>',
    speed: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 0 0-6.88 17.23"/><path d="M12 2a10 10 0 0 1 6.88 17.23"/><line x1="12" y1="12" x2="12" y2="8"/></svg>',
    warn: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
    cross: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>',
    logo: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>'
  };

  function renderResults(vehicle, motHistory, products, reg) {
    while (resultsEl.firstChild) resultsEl.removeChild(resultsEl.firstChild);

    var card = el('div', 'apl-vehicle-card');
    var header = el('div', 'apl-vehicle-card__header');
    var regBadge = el('div', 'apl-vehicle-card__reg');
    regBadge.appendChild(el('span', 'apl-vehicle-card__reg-flag', 'GB'));
    regBadge.appendChild(document.createTextNode(formatReg(reg)));
    header.appendChild(regBadge);
    header.appendChild(el('h2', 'apl-vehicle-card__title', (vehicle.make || '') + ' ' + (vehicle.model || '')));
    header.appendChild(el('p', 'apl-vehicle-card__subtitle', vehicle.yearOfManufacture ? vehicle.yearOfManufacture + ' \u2022 ' + (vehicle.colour || '') : (vehicle.colour || '')));
    card.appendChild(header);

    var details = el('div', 'apl-details');
    var defs = [
      { label: 'Fuel Type', value: vehicle.fuelType || '\u2014' },
      { label: 'Engine', value: vehicle.engineCapacity ? vehicle.engineCapacity + 'cc' : '\u2014' },
      { label: 'Colour', value: vehicle.colour || '\u2014' },
      { label: 'Year', value: vehicle.yearOfManufacture || '\u2014' }
    ];

    if (root.dataset.showTax !== 'false') {
      var motStatus = vehicle.motStatus || 'Unknown';
      var motVal = el('div');
      var motBadge = el('span', 'apl-status ' + (motStatus === 'Valid' ? 'apl-status--pass' : motStatus === 'Not valid' ? 'apl-status--fail' : 'apl-status--warn'));
      motBadge.appendChild(el('span', 'apl-status__dot'));
      motBadge.appendChild(document.createTextNode(motStatus));
      motVal.appendChild(motBadge);
      if (vehicle.motExpiryDate) { var exp = el('p', 'apl-mot-card__expiry', 'Expires: ' + formatDate(vehicle.motExpiryDate)); exp.style.marginTop = '4px'; motVal.appendChild(exp); }
      defs.push({ label: 'MOT Status', valueEl: motVal });

      var taxStatus = vehicle.taxStatus || 'Unknown';
      var taxVal = el('div');
      var taxBadge = el('span', 'apl-status ' + (taxStatus === 'Taxed' ? 'apl-status--pass' : taxStatus === 'SORN' ? 'apl-status--warn' : 'apl-status--fail'));
      taxBadge.appendChild(el('span', 'apl-status__dot'));
      taxBadge.appendChild(document.createTextNode(taxStatus));
      taxVal.appendChild(taxBadge);
      if (vehicle.taxDueDate) { var tExp = el('p', 'apl-mot-card__expiry', 'Due: ' + formatDate(vehicle.taxDueDate)); tExp.style.marginTop = '4px'; taxVal.appendChild(tExp); }
      defs.push({ label: 'Tax Status', valueEl: taxVal });
    }

    for (var i = 0; i < defs.length; i++) {
      var d = el('div', 'apl-detail');
      d.appendChild(el('p', 'apl-detail__label', defs[i].label));
      if (defs[i].valueEl) d.appendChild(defs[i].valueEl);
      else d.appendChild(el('p', 'apl-detail__value', defs[i].value));
      details.appendChild(d);
    }
    card.appendChild(details);

    if (products.length > 0) {
      var partsBtn = el('button', 'apl-find-parts');
      partsBtn.appendChild(svgIcon(ICONS.search));
      partsBtn.appendChild(document.createTextNode('Find ' + products.length + ' Compatible Part' + (products.length !== 1 ? 's' : '')));
      partsBtn.addEventListener('click', function() { window.location.href = '/collections/all?make=' + encodeURIComponent(vehicle.make); });
      card.appendChild(partsBtn);
    }
    resultsEl.appendChild(card);

    try { localStorage.setItem('autosync_vehicle', JSON.stringify({ makeName: vehicle.make, modelName: vehicle.model, year: String(vehicle.yearOfManufacture), source: 'plate-lookup' })); } catch(e) {}

    
    if (root.dataset.showMot !== 'false' && motHistory && motHistory.motTests && motHistory.motTests.length > 0) {
      var motSection = el('div', 'apl-mot-section');
      var motHeader = el('div', 'apl-mot-header');
      var motTitle = el('h3', 'apl-mot-title');
      motTitle.appendChild(svgIcon(ICONS.shield));
      motTitle.appendChild(document.createTextNode('MOT History'));
      motHeader.appendChild(motTitle);
      motHeader.appendChild(el('span', 'apl-mot-count', motHistory.motTests.length + ' test' + (motHistory.motTests.length !== 1 ? 's' : '')));
      motSection.appendChild(motHeader);

      var timeline = el('ul', 'apl-mot-timeline');
      var tests = motHistory.motTests.slice(0, 10);
      for (var ti = 0; ti < tests.length; ti++) {
        var test = tests[ti];
        var passed = test.testResult === 'PASSED';
        var item = el('li', 'apl-mot-item');
        item.appendChild(el('span', 'apl-mot-dot ' + (passed ? 'apl-mot-dot--pass' : 'apl-mot-dot--fail')));

        var motCard = el('div', 'apl-mot-card');
        var motTop = el('div', 'apl-mot-card__top');
        var dateAndStatus = el('div');
        dateAndStatus.appendChild(el('span', 'apl-mot-card__date', formatDate(test.completedDate)));
        var sBadge = el('span', 'apl-status ' + (passed ? 'apl-status--pass' : 'apl-status--fail'));
        sBadge.appendChild(el('span', 'apl-status__dot'));
        sBadge.appendChild(document.createTextNode(passed ? 'Passed' : 'Failed'));
        sBadge.style.marginLeft = '10px';
        dateAndStatus.appendChild(sBadge);
        motTop.appendChild(dateAndStatus);

        if (test.odometerValue && test.odometerValue !== '0') {
          var mileage = el('span', 'apl-mot-card__mileage');
          mileage.appendChild(svgIcon(ICONS.speed));
          mileage.appendChild(document.createTextNode(Number(test.odometerValue).toLocaleString() + ' ' + (test.odometerUnit || 'mi')));
          motTop.appendChild(mileage);
        }
        motCard.appendChild(motTop);
        if (test.expiryDate) motCard.appendChild(el('p', 'apl-mot-card__expiry', 'Expires: ' + formatDate(test.expiryDate)));

        if (test.defects && test.defects.length > 0) {
          var defectsDiv = el('div', 'apl-defects');
          for (var di = 0; di < test.defects.length; di++) {
            var defect = test.defects[di];
            var dtype = (defect.type || 'advisory').toLowerCase();
            var defEl = el('div', 'apl-defect apl-defect--' + dtype);
            var dIconEl = el('span', 'apl-defect__icon');
            dIconEl.appendChild(svgIcon(dtype === 'advisory' ? ICONS.warn : ICONS.cross));
            defEl.appendChild(dIconEl);
            var defText = el('div');
            defText.appendChild(el('span', 'apl-defect__type', defect.type || 'Advisory'));
            defText.appendChild(document.createTextNode(' ' + (defect.text || '')));
            defEl.appendChild(defText);
            defectsDiv.appendChild(defEl);
          }
          motCard.appendChild(defectsDiv);
        }
        item.appendChild(motCard);
        timeline.appendChild(item);
      }
      motSection.appendChild(timeline);
      resultsEl.appendChild(motSection);
    }

    
    if (root.dataset.showProducts !== 'false' && products.length > 0) {
      var prodSection = el('div', 'apl-products-section');
      prodSection.appendChild(el('h3', 'apl-products-title', products.length + ' Compatible Part' + (products.length !== 1 ? 's' : '')));
      var prodGrid = el('div', 'apl-products-grid');
      for (var pi = 0; pi < Math.min(products.length, 12); pi++) {
        var p = products[pi];
        var prodCard = document.createElement('a');
        prodCard.href = '/products/' + p.handle;
        prodCard.className = 'apl-product';
        if (p.image_url) { var img = document.createElement('img'); img.className = 'apl-product__img'; img.src = p.image_url; img.alt = p.title; img.loading = 'lazy'; prodCard.appendChild(img); }
        var body = el('div', 'apl-product__body');
        body.appendChild(el('p', 'apl-product__title', p.title));
        if (p.price) body.appendChild(el('p', 'apl-product__price', '\u00A3' + Number(p.price).toFixed(2)));
        prodCard.appendChild(body);
        prodGrid.appendChild(prodCard);
      }
      prodSection.appendChild(prodGrid);
      resultsEl.appendChild(prodSection);
    }

    
    var footer = el('div', 'apl-footer');
    footer.appendChild(svgIcon(ICONS.logo));
    var pw = el('span');
    pw.textContent = 'Powered by ';
    pw.appendChild(el('strong', '', 'AutoSync'));
    footer.appendChild(pw);
    resultsEl.appendChild(footer);
    resultsEl.style.display = 'block';
  }

  function formatReg(reg) { reg = reg.replace(/\s/g, '').toUpperCase(); if (reg.length === 7) return reg.substring(0, 4) + ' ' + reg.substring(4); return reg; }
  function formatDate(dateStr) { if (!dateStr) return '\u2014'; try { var d = new Date(dateStr); if (isNaN(d.getTime())) return dateStr; return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }); } catch(e) { return dateStr; } }
})();
</script>

{% schema %}
{
  "name": "Plate Lookup (UK)",
  "target": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find Parts by Registration" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Enter your UK registration number to find compatible parts" },
    { "type": "text", "id": "placeholder_text", "label": "Placeholder Text", "default": "Enter reg number" },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "Look Up" },
    { "type": "select", "id": "container_width", "label": "Container Width", "options": [{ "value": "full", "label": "Full Width" }, { "value": "1400", "label": "Extra Wide (1400px)" }, { "value": "1200", "label": "Standard (1200px)" }, { "value": "800", "label": "Narrow (800px)" }], "default": "1200" },
    { "type": "range", "id": "container_padding", "label": "Container Padding", "min": 0, "max": 60, "step": 4, "default": 24, "unit": "px" },
    { "type": "select", "id": "heading_alignment", "label": "Heading Alignment", "options": [{ "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }], "default": "center" },
    { "type": "checkbox", "id": "show_mot_history", "label": "Show MOT History Timeline", "default": true },
    { "type": "checkbox", "id": "show_tax_status", "label": "Show MOT & Tax Status", "default": true },
    { "type": "checkbox", "id": "show_products", "label": "Show Compatible Products", "default": true },
    { "type": "color", "id": "primary_color", "label": "Primary Color", "default": "#2563eb" },
    { "type": "color", "id": "background_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#1a1a2e" },
    { "type": "color", "id": "muted_color", "label": "Muted Text Color", "default": "#6b7280" },
    { "type": "color", "id": "border_color", "label": "Border Color", "default": "#e5e7eb" },
    { "type": "color", "id": "card_bg", "label": "Card Background", "default": "#f9fafb" },
    { "type": "range", "id": "border_radius", "label": "Border Radius", "min": 0, "max": 24, "step": 2, "default": 12, "unit": "px" },
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 0, "max": 100, "step": 4, "default": 40, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 100, "step": 4, "default": 40, "unit": "px" }
  ]
}
{% endschema %}
