{% liquid
  assign proxy_url = shop.url | append: '/apps/autosync'
  assign logo_url = 'autosync-logo.svg' | asset_url
  assign allowed_widgets_raw = shop.metafields['$app:autosync']['allowed_widgets'].value
  assign plate_allowed = false
  if allowed_widgets_raw != blank
if allowed_widgets_raw.plate == true
assign plate_allowed = true
endif
  endif
%}
{% if plate_allowed == false %}
<!-- widget not available on current plan -->
{% else %}
<div class="apl-root" data-apl-root data-proxy-url="{{ proxy_url }}" data-logo-url="{{ logo_url }}" data-hide-watermark="{{ shop.metafields['$app:autosync']['hide_watermark'].value | default: false }}" data-show-mot="{{ block.settings.show_mot_history | default: true }}" data-show-tax="{{ block.settings.show_tax_status | default: true }}" data-result-style="{{ block.settings.result_style | default: 'compact' }}" data-content-position="{{ block.settings.content_position | default: 'left' }}" data-show-co2="{{ block.settings.show_co2 | default: true }}" data-show-weight="{{ block.settings.show_weight | default: true }}" data-show-mileage="{{ block.settings.show_mileage | default: true }}" id="apl-{{ block.id }}" style="--apl-primary:{{ block.settings.primary_color | default: '#005bd2' }};--apl-bg:{{ block.settings.background_color | default: '#ffffff' }};--apl-text:{{ block.settings.text_color | default: '#1a1a2e' }};--apl-muted:{{ block.settings.muted_color | default: '#6b7280' }};--apl-border:{{ block.settings.border_color | default: '#e5e7eb' }};--apl-card-bg:{{ block.settings.card_bg | default: '#f8f9fa' }};--apl-radius:{{ block.settings.border_radius | default: 8 }}px;--as-primary:{{ block.settings.primary_color | default: '#005bd2' }};--as-bg:{{ block.settings.background_color | default: '#ffffff' }};--as-text:{{ block.settings.text_color | default: '#1a1a2e' }};--as-muted:{{ block.settings.muted_color | default: '#6b7280' }};--as-border:{{ block.settings.border_color | default: '#e5e7eb' }};--as-card-bg:{{ block.settings.card_bg | default: '#f8f9fa' }};--as-radius:{{ block.settings.border_radius | default: 8 }}px;--as-btn-bg:{{ block.settings.button_color | default: block.settings.primary_color | default: '#005bd2' }};--as-btn-text:{{ block.settings.button_text_color | default: '#ffffff' }};--as-section-gap:{{ block.settings.section_gap | default: 16 }}px;--as-section-gap-top:{{ block.settings.section_gap_top | default: 0 }}px;--as-heading-size:{% case block.settings.heading_size %}{% when 'small' %}18px{% when 'large' %}28px{% else %}22px{% endcase %};padding-top:{{ block.settings.padding_top | default: 40 }}px;padding-bottom:{{ block.settings.padding_bottom | default: 40 }}px;max-width:{% if block.settings.container_width == 'full' %}100%{% else %}{{ block.settings.container_width | default: '1200' }}px{% endif %};padding-left:{{ block.settings.container_padding | default: 24 }}px;padding-right:{{ block.settings.container_padding | default: 24 }}px;">
  <div class="apl-container">
    <!-- Left: Text content (shown initially, replaced by vehicle result on lookup) -->
    <div class="apl-content" data-apl-content>
      {% if block.settings.heading != blank %}
      <h2 class="apl-heading">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
      <p class="apl-subheading">{{ block.settings.subheading }}</p>
      {% endif %}
      {% if block.settings.description_text != blank %}
      <p class="apl-description">{{ block.settings.description_text }}</p>
      {% endif %}
    </div>
    <!-- Right: Form + History -->
    <div class="apl-form-side" data-apl-form-side>
      <div class="apl-plate-form">
        <div class="apl-plate-input-wrap">
          <div class="apl-plate-badge">
            <svg width="18" height="12" viewBox="0 0 60 40" style="display:block;"><rect width="60" height="40" fill="#012169"/><path d="M0 0L60 40M60 0L0 40" stroke="#fff" stroke-width="6"/><path d="M0 0L60 40M60 0L0 40" stroke="#C8102E" stroke-width="3"/><path d="M30 0V40M0 20H60" stroke="#fff" stroke-width="10"/><path d="M30 0V40M0 20H60" stroke="#C8102E" stroke-width="6"/></svg>
            <span class="apl-plate-badge__text">UK</span>
          </div>
          <input type="text" class="apl-plate-input" data-apl-input placeholder="{{ block.settings.placeholder_text | default: 'Enter reg (e.g. AB12 CDE)' }}" maxlength="8" autocomplete="off" spellcheck="false" aria-label="Enter UK vehicle registration number"/>
        </div>
        <button type="button" class="apl-submit-btn" data-apl-submit aria-label="Look up vehicle by registration number">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <span>{{ block.settings.button_text | default: "Look Up" }}</span>
        </button>
      </div>
      <div class="apl-history" data-apl-history style="display:none;"></div>
    </div>
  </div>
  <div class="apl-loading" data-apl-loading style="display:none;"><div class="apl-spinner"></div><p class="apl-loading__text">Looking up vehicle...</p></div>
  <div class="apl-error" data-apl-error style="display:none;">
    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.4"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
    <p class="apl-error__msg" data-apl-error-msg>Something went wrong.</p>
    <button type="button" class="apl-error__retry" data-apl-retry aria-label="Retry vehicle lookup">Try Again</button>
  </div>
  <div class="apl-results" data-apl-results style="display:none;"></div>
</div>
{{ 'autosync-plate-lookup.css' | asset_url | stylesheet_tag }}
<script src="{{ "autosync-plate-lookup.js" | asset_url }}" defer></script>
{% endif %}
{% schema %}
{
  "name": "Plate Lookup (UK)",
  "target": "section",
  "settings": [
{ "type": "header", "content": "Content" },
{ "type": "text", "id": "heading", "label": "Heading", "default": "Find Parts by Registration" },
{ "type": "text", "id": "subheading", "label": "Subheading", "default": "Enter your UK registration number to find compatible parts" },
{ "type": "textarea", "id": "description_text", "label": "Description Text", "default": "Simply enter your UK registration number and we'll instantly identify your vehicle. Find the exact parts that fit, check MOT history, and browse compatible products." },
{ "type": "text", "id": "placeholder_text", "label": "Placeholder Text", "default": "Enter reg (e.g. AB12 CDE)" },
{ "type": "text", "id": "button_text", "label": "Button Text", "default": "Look Up" },
{ "type": "select", "id": "heading_alignment", "label": "Heading Alignment", "options": [{ "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }], "default": "left" },
{ "type": "select", "id": "heading_size", "label": "Heading Size", "options": [{ "value": "small", "label": "Small" }, { "value": "medium", "label": "Medium" }, { "value": "large", "label": "Large" }], "default": "medium" },
{ "type": "select", "id": "content_position", "label": "Text Position", "options": [{ "value": "left", "label": "Left" }, { "value": "right", "label": "Right" }], "default": "left" },
{ "type": "header", "content": "Features" },
{ "type": "checkbox", "id": "show_mot_history", "label": "Show MOT History", "default": true },
{ "type": "checkbox", "id": "show_tax_status", "label": "Show MOT & Tax Status", "default": true },
{ "type": "select", "id": "result_style", "label": "Result Display", "options": [{ "value": "compact", "label": "Compact Bar (Recommended)" }, { "value": "expanded", "label": "Full Card (Classic)" }], "default": "compact" },
{ "type": "checkbox", "id": "show_co2", "label": "Show CO₂ Emissions", "default": true },
{ "type": "checkbox", "id": "show_weight", "label": "Show Vehicle Weight", "default": true },
{ "type": "checkbox", "id": "show_mileage", "label": "Show Last Mileage", "default": true },
{ "type": "header", "content": "Colors" },
{ "type": "color", "id": "primary_color", "label": "Primary Color", "default": "#005bd2" },
{ "type": "color", "id": "background_color", "label": "Background Color", "default": "#ffffff" },
{ "type": "color", "id": "text_color", "label": "Text Color", "default": "#1a1a2e" },
{ "type": "color", "id": "muted_color", "label": "Muted Text Color", "default": "#6b7280" },
{ "type": "color", "id": "border_color", "label": "Border Color", "default": "#e5e7eb" },
{ "type": "color", "id": "card_bg", "label": "Card Background", "default": "#f8f9fa" },
{ "type": "color", "id": "button_color", "label": "Button Color", "default": "#005bd2" },
{ "type": "color", "id": "button_text_color", "label": "Button Text Color", "default": "#ffffff" },
{ "type": "header", "content": "Layout" },
{ "type": "select", "id": "container_width", "label": "Container Width", "options": [{ "value": "full", "label": "Full Width" }, { "value": "1400", "label": "Extra Wide (1400px)" }, { "value": "1200", "label": "Standard (1200px)" }, { "value": "1000", "label": "Medium (1000px)" }, { "value": "800", "label": "Narrow (800px)" }], "default": "1200" },
{ "type": "range", "id": "container_padding", "label": "Container Padding", "min": 0, "max": 60, "step": 4, "default": 24, "unit": "px" },
{ "type": "range", "id": "border_radius", "label": "Border Radius", "min": 0, "max": 24, "step": 2, "default": 8, "unit": "px" },
{ "type": "range", "id": "padding_top", "label": "Top Padding", "min": 0, "max": 100, "step": 4, "default": 40, "unit": "px" },
{ "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 100, "step": 4, "default": 40, "unit": "px" },
{ "type": "range", "id": "section_gap", "label": "Bottom Margin (Gap Between Sections)", "min": 0, "max": 60, "step": 4, "default": 16, "unit": "px" },
{
"type": "range",
"id": "section_gap_top",
"label": "Top Margin (Gap Above Section)",
"min": 0,
"max": 60,
"step": 4,
"default": 0,
"unit": "px"
}
  ]
}
{% endschema %}
