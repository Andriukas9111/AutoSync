{% comment %}
  AutoSync Plate Lookup — Premium Edition
  Enterprise-only — DVLA VES + MOT History via App Proxy
{% endcomment %}

{% liquid
  assign proxy_url = shop.url | append: '/apps/autosync'
  assign logo_url = 'autosync-logo.svg' | asset_url
%}

<div
  class="apl-root"
  data-apl-root
  data-proxy-url="{{ proxy_url }}"
  data-logo-url="{{ logo_url }}"
  data-show-mot="{{ block.settings.show_mot_history | default: true }}"
  data-show-products="{{ block.settings.show_products | default: true }}"
  data-show-tax="{{ block.settings.show_tax_status | default: true }}"
  id="apl-{{ block.id }}"
  style="
    --apl-primary: {{ block.settings.primary_color | default: '#2563eb' }};
    --apl-bg: {{ block.settings.background_color | default: '#ffffff' }};
    --apl-text: {{ block.settings.text_color | default: '#1a1a2e' }};
    --apl-muted: {{ block.settings.muted_color | default: '#6b7280' }};
    --apl-border: {{ block.settings.border_color | default: '#e5e7eb' }};
    --apl-card-bg: {{ block.settings.card_bg | default: '#f9fafb' }};
    --apl-radius: {{ block.settings.border_radius | default: 12 }}px;
    --apl-success: #10b981;
    --apl-danger: #ef4444;
    --apl-warning: #f59e0b;
    padding-top: {{ block.settings.padding_top | default: 40 }}px;
    padding-bottom: {{ block.settings.padding_bottom | default: 40 }}px;
    max-width: {% if block.settings.container_width == 'full' %}100%{% else %}{{ block.settings.container_width | default: '1200' }}px{% endif %};
    padding-left: {{ block.settings.container_padding | default: 24 }}px;
    padding-right: {{ block.settings.container_padding | default: 24 }}px;
  "
>
  {% if block.settings.heading != blank %}
    <div class="apl-heading-wrap" style="text-align: {{ block.settings.heading_alignment | default: 'center' }};">
      <div class="apl-heading-accent" {% if block.settings.heading_alignment == 'left' %}style="margin-left: 0;"{% endif %}></div>
      <h2 class="apl-heading">{{ block.settings.heading }}</h2>
    </div>
  {% endif %}

  {% if block.settings.subheading != blank %}
    <p class="apl-subheading" style="text-align: {{ block.settings.heading_alignment | default: 'center' }};">{{ block.settings.subheading }}</p>
  {% endif %}

  <div class="apl-plate-form">
    <div class="apl-plate-input-wrap">
      <div class="apl-plate-badge">
        <div class="apl-plate-badge__flag">
          <div class="apl-plate-badge__stars">
            <span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span>
          </div>
          <span class="apl-plate-badge__text">GB</span>
        </div>
      </div>
      <input
        type="text"
        class="apl-plate-input"
        data-apl-input
        placeholder="{{ block.settings.placeholder_text | default: 'Enter reg number' }}"
        maxlength="8"
        autocomplete="off"
        spellcheck="false"
      />
    </div>
    <button type="button" class="apl-submit-btn" data-apl-submit>
      <svg class="apl-submit-btn__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <span>{{ block.settings.button_text | default: "Look Up" }}</span>
    </button>
  </div>

  <div class="apl-loading" data-apl-loading style="display:none;">
    <div class="apl-spinner"></div>
    <p class="apl-loading__text">Looking up vehicle...</p>
  </div>

  <div class="apl-error" data-apl-error style="display:none;">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
    <p class="apl-error__msg" data-apl-error-msg>Something went wrong.</p>
    <button type="button" class="apl-error__retry" data-apl-retry>Try Again</button>
  </div>

  <div class="apl-results" data-apl-results style="display:none;"></div>
</div>

{{ 'autosync-plate-lookup.css' | asset_url | stylesheet_tag }}

<script>
(function() {
  var root = document.getElementById('apl-{{ block.id }}');
  if (!root) return;

  var proxyUrl = root.dataset.proxyUrl;
  var logoUrl = root.dataset.logoUrl;
  var loadingEl = root.querySelector('[data-apl-loading]');
  var errorEl = root.querySelector('[data-apl-error]');
  var resultsEl = root.querySelector('[data-apl-results]');
  var input = root.querySelector('[data-apl-input]');
  var submitBtn = root.querySelector('[data-apl-submit]');
  var retryBtn = root.querySelector('[data-apl-retry]');
  var btnHTML = submitBtn ? submitBtn.innerHTML : '';
  var lastReg = '';

  if (!input || !submitBtn) return;

  input.addEventListener('input', function() { this.value = this.value.toUpperCase().replace(/[^A-Z0-9 ]/g, ''); });
  input.addEventListener('keydown', function(e) { if (e.key === 'Enter') submitBtn.click(); });
  if (retryBtn) retryBtn.addEventListener('click', function() { if (lastReg) doLookup(lastReg); });

  submitBtn.addEventListener('click', function() {
    var reg = input.value.trim().replace(/\s+/g, '');
    if (reg.length < 2) return;
    lastReg = reg;
    doLookup(reg);
  });

  function doLookup(reg) {
    submitBtn.disabled = true;
    submitBtn.textContent = 'Looking up...';
    errorEl.style.display = 'none';
    resultsEl.style.display = 'none';

    fetch(proxyUrl + '?path=plate-lookup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ registration: reg }),
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = btnHTML;
        if (data.error) { showError(data.error); return; }
        if (data.vehicle) renderResults(data.vehicle, data.motHistory, data.compatibleProducts || [], reg);
      })
      .catch(function() {
        submitBtn.disabled = false;
        submitBtn.innerHTML = btnHTML;
        showError('Failed to look up registration. Please try again.');
      });
  }

  function showError(msg) {
    var m = errorEl.querySelector('[data-apl-error-msg]');
    if (m) m.textContent = msg;
    errorEl.style.display = 'block';
    resultsEl.style.display = 'none';
  }

  function el(tag, cls, txt) {
    var e = document.createElement(tag);
    if (cls) e.className = cls;
    if (txt !== undefined && txt !== null) e.textContent = String(txt);
    return e;
  }

  function svgIcon(mk) {
    var t = document.createElement('template');
    t.innerHTML = mk.trim();
    return t.content.firstChild;
  }

  var IC = {
    shield: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    chevDown: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>',
    chevSm: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>',
    arrow: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>'
  };

  function renderResults(v, motHist, products, reg) {
    while (resultsEl.firstChild) resultsEl.removeChild(resultsEl.firstChild);

    /* Vehicle Card */
    var card = el('div', 'apl-vehicle-card');
    var hdr = el('div', 'apl-vehicle-card__header');
    var regB = el('div', 'apl-vehicle-card__reg');
    regB.appendChild(el('span', 'apl-vehicle-card__reg-flag', 'GB'));
    regB.appendChild(el('span', 'apl-vehicle-card__reg-text', fmtReg(reg)));
    hdr.appendChild(regB);
    hdr.appendChild(el('h2', 'apl-vehicle-card__title', (v.make || '') + ' ' + (v.model || '')));
    var sub = v.yearOfManufacture ? v.yearOfManufacture + ' \u2022 ' + (v.colour || '') : (v.colour || '');
    if (sub) hdr.appendChild(el('p', 'apl-vehicle-card__subtitle', sub));
    card.appendChild(hdr);

    /* Details grid */
    var dg = el('div', 'apl-details');
    var defs = [
      ['Fuel Type', v.fuelType || '\u2014'],
      ['Engine', v.engineCapacity ? v.engineCapacity + 'cc' : '\u2014'],
      ['Colour', v.colour || '\u2014'],
      ['Year', v.yearOfManufacture || '\u2014']
    ];

    if (root.dataset.showTax !== 'false') {
      defs.push(['MOT Status', null, motBadge(v.motStatus, v.motExpiryDate, 'Expires')]);
      defs.push(['Tax Status', null, taxBadge(v.taxStatus, v.taxDueDate)]);
    }

    for (var i = 0; i < defs.length; i++) {
      var dd = el('div', 'apl-detail');
      dd.appendChild(el('p', 'apl-detail__label', defs[i][0]));
      if (defs[i][2]) dd.appendChild(defs[i][2]);
      else dd.appendChild(el('p', 'apl-detail__value', defs[i][1]));
      dg.appendChild(dd);
    }
    card.appendChild(dg);
    resultsEl.appendChild(card);

    try { localStorage.setItem('autosync_vehicle', JSON.stringify({ makeName: v.make, modelName: v.model, year: String(v.yearOfManufacture), source: 'plate-lookup' })); } catch(e) {}

    /* Find Parts Button */
    if (v.make) {
      var fpw = el('div', 'apl-find-parts-wrap');
      var fpb = el('button', 'apl-find-parts');
      fpb.appendChild(document.createTextNode('Find Parts for This Vehicle '));
      fpb.appendChild(svgIcon(IC.arrow));
      fpb.addEventListener('click', function() {
        var mk = v.make, md = v.model || '';
        fetch(proxyUrl + '?path=collection-lookup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ make: mk, model: md })
        }).then(function(r) { return r.json(); }).then(function(d) {
          if (d.data && d.data.found && d.data.url) window.location.href = d.data.url;
          else window.location.href = '/collections/' + mk.toLowerCase().replace(/\s+/g, '-') + '-' + md.toLowerCase().replace(/\s+/g, '-') + '-parts';
        }).catch(function() {
          window.location.href = '/collections/' + mk.toLowerCase().replace(/\s+/g, '-') + '-' + (md || '').toLowerCase().replace(/\s+/g, '-') + '-parts';
        });
      });
      fpw.appendChild(fpb);
      resultsEl.appendChild(fpw);
    }

    /* MOT History Accordion */
    var tests = (motHist && motHist.motTests) ? motHist.motTests : [];
    if (root.dataset.showMot !== 'false' && tests.length > 0) {
      var ms = el('div', 'apl-mot-section');

      /* Toggle bar */
      var tog = el('button', 'apl-mot-toggle');
      tog.appendChild(svgIcon(IC.shield));
      tog.appendChild(el('span', 'apl-mot-toggle__title', 'MOT History'));
      tog.appendChild(el('span', 'apl-mot-toggle__count', tests.length + ' test' + (tests.length !== 1 ? 's' : '')));
      var chev = el('span', 'apl-mot-toggle__chevron');
      chev.appendChild(svgIcon(IC.chevDown));
      tog.appendChild(chev);
      ms.appendChild(tog);

      /* Test list */
      var list = el('ul', 'apl-mot-list');
      var show5 = tests.length > 5;
      var visible = show5 ? 5 : tests.length;

      for (var ti = 0; ti < tests.length; ti++) {
        var t = tests[ti];
        var passed = t.testResult === 'PASSED';
        var li = el('li', '');
        if (ti >= visible) li.style.display = 'none';
        li.dataset.motIdx = ti;

        var hasDef = t.defects && t.defects.length > 0;
        var row = el('div', 'apl-mot-row' + (hasDef ? ' apl-mot-row--has-defects' : ''));
        var badge = el('span', 'apl-status ' + (passed ? 'apl-status--pass' : 'apl-status--fail'));
        badge.appendChild(el('span', 'apl-status__dot'));
        badge.appendChild(document.createTextNode(passed ? 'Pass' : 'Fail'));
        row.appendChild(el('span', 'apl-mot-row__date', fmtDate(t.completedDate)));
        row.appendChild(badge);
        if (t.odometerValue && t.odometerValue !== '0') {
          row.appendChild(el('span', 'apl-mot-row__mileage', Number(t.odometerValue).toLocaleString() + ' ' + (t.odometerUnit || 'mi')));
        }
        if (hasDef) {
          var rc = el('span', 'apl-mot-row__chevron');
          rc.appendChild(svgIcon(IC.chevSm));
          row.appendChild(rc);
        }
        li.appendChild(row);

        /* Nested defects */
        if (hasDef) {
          var dDiv = el('div', 'apl-mot-defects');
          for (var di = 0; di < t.defects.length; di++) {
            var df = t.defects[di];
            var dt = (df.type || 'advisory').toLowerCase();
            var de = el('div', 'apl-defect apl-defect--' + dt);
            de.appendChild(el('span', 'apl-defect__type', df.type || 'Advisory'));
            de.appendChild(document.createTextNode(df.text || ''));
            dDiv.appendChild(de);
          }
          li.appendChild(dDiv);
          (function(r, d) {
            r.addEventListener('click', function() {
              var open = d.classList.contains('apl-mot-defects--open');
              d.classList.toggle('apl-mot-defects--open');
              var ch = r.querySelector('.apl-mot-row__chevron');
              if (ch) ch.classList.toggle('apl-mot-row__chevron--open');
            });
          })(row, dDiv);
        }
        list.appendChild(li);
      }

      /* Show all link */
      if (show5) {
        var sa = el('button', 'apl-mot-show-all', 'Show all ' + tests.length + ' tests');
        sa.addEventListener('click', function() {
          var items = list.querySelectorAll('li');
          for (var j = 0; j < items.length; j++) items[j].style.display = '';
          this.style.display = 'none';
        });
        list.appendChild(el('li', '')).appendChild(sa);
      }
      ms.appendChild(list);

      tog.addEventListener('click', function() {
        tog.classList.toggle('apl-mot-toggle--open');
        list.classList.toggle('apl-mot-list--open');
      });

      resultsEl.appendChild(ms);
    }

    /* Compatible Products */
    if (root.dataset.showProducts !== 'false' && products.length > 0) {
      var ps = el('div', 'apl-products-section');
      ps.appendChild(el('h3', 'apl-products-title', 'Compatible Parts'));
      var pg = el('div', 'apl-products-grid');
      for (var pi = 0; pi < Math.min(products.length, 6); pi++) {
        var p = products[pi];
        var pc = document.createElement('a');
        pc.href = '/products/' + p.handle;
        pc.className = 'apl-product';
        if (p.image_url) { var im = document.createElement('img'); im.className = 'apl-product__img'; im.src = p.image_url; im.alt = p.title; im.loading = 'lazy'; pc.appendChild(im); }
        var bd = el('div', 'apl-product__body');
        bd.appendChild(el('p', 'apl-product__title', p.title));
        if (p.price) bd.appendChild(el('p', 'apl-product__price', '\u00A3' + Number(p.price).toFixed(2)));
        pc.appendChild(bd);
        pg.appendChild(pc);
      }
      ps.appendChild(pg);
      resultsEl.appendChild(ps);
    }

    /* Footer */
    var ft = el('div', 'apl-footer');
    var logo = document.createElement('img');
    logo.src = logoUrl;
    logo.alt = 'AutoSync';
    logo.width = 18;
    logo.height = 18;
    logo.style.opacity = '0.5';
    ft.appendChild(logo);
    var pw = el('span');
    pw.textContent = 'Powered by ';
    pw.appendChild(el('strong', '', 'AutoSync'));
    ft.appendChild(pw);
    resultsEl.appendChild(ft);
    resultsEl.style.display = 'block';
  }

  function motBadge(status, expiry, label) {
    var w = el('div');
    var s = status || 'Unknown';
    var cls = s === 'Valid' ? 'apl-status--pass' : s === 'Not valid' ? 'apl-status--fail' : 'apl-status--grey';
    var b = el('span', 'apl-status ' + cls);
    b.appendChild(el('span', 'apl-status__dot'));
    b.appendChild(document.createTextNode(s));
    w.appendChild(b);
    if (expiry) { var e = el('p', 'apl-detail__sub', (label || 'Expires') + ': ' + fmtDate(expiry)); e.style.fontSize = '11px'; e.style.color = 'var(--apl-muted)'; e.style.margin = '4px 0 0'; w.appendChild(e); }
    return w;
  }

  function taxBadge(status, due) {
    var w = el('div');
    var s = status || 'Unknown';
    var cls = s === 'Taxed' ? 'apl-status--pass' : s === 'SORN' ? 'apl-status--warn' : 'apl-status--fail';
    var b = el('span', 'apl-status ' + cls);
    b.appendChild(el('span', 'apl-status__dot'));
    b.appendChild(document.createTextNode(s));
    w.appendChild(b);
    if (due) { var e = el('p', '', 'Due: ' + fmtDate(due)); e.style.fontSize = '11px'; e.style.color = 'var(--apl-muted)'; e.style.margin = '4px 0 0'; w.appendChild(e); }
    return w;
  }

  function fmtReg(r) { r = r.replace(/\s/g, '').toUpperCase(); return r.length === 7 ? r.substring(0, 4) + ' ' + r.substring(4) : r; }
  function fmtDate(d) { if (!d) return '\u2014'; try { var dt = new Date(d); return isNaN(dt.getTime()) ? d : dt.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }); } catch(e) { return d; } }
})();
</script>

{% schema %}
{
  "name": "Plate Lookup (UK)",
  "target": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find Parts by Registration" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Enter your UK registration number to find compatible parts" },
    { "type": "text", "id": "placeholder_text", "label": "Placeholder Text", "default": "Enter reg number" },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "Look Up" },
    { "type": "select", "id": "container_width", "label": "Container Width", "options": [{ "value": "full", "label": "Full Width" }, { "value": "1400", "label": "Extra Wide (1400px)" }, { "value": "1200", "label": "Standard (1200px)" }, { "value": "800", "label": "Narrow (800px)" }], "default": "1200" },
    { "type": "range", "id": "container_padding", "label": "Container Padding", "min": 0, "max": 60, "step": 4, "default": 24, "unit": "px" },
    { "type": "select", "id": "heading_alignment", "label": "Heading Alignment", "options": [{ "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }], "default": "center" },
    { "type": "checkbox", "id": "show_mot_history", "label": "Show MOT History Timeline", "default": true },
    { "type": "checkbox", "id": "show_tax_status", "label": "Show MOT & Tax Status", "default": true },
    { "type": "checkbox", "id": "show_products", "label": "Show Compatible Products", "default": true },
    { "type": "color", "id": "primary_color", "label": "Primary Color", "default": "#2563eb" },
    { "type": "color", "id": "background_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#1a1a2e" },
    { "type": "color", "id": "muted_color", "label": "Muted Text Color", "default": "#6b7280" },
    { "type": "color", "id": "border_color", "label": "Border Color", "default": "#e5e7eb" },
    { "type": "color", "id": "card_bg", "label": "Card Background", "default": "#f9fafb" },
    { "type": "range", "id": "border_radius", "label": "Border Radius", "min": 0, "max": 24, "step": 2, "default": 12, "unit": "px" },
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 0, "max": 100, "step": 4, "default": 40, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 100, "step": 4, "default": 40, "unit": "px" }
  ]
}
{% endschema %}
